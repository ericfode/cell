-- ═══════════════════════════════════════════════════════════════
-- FRAME 0: Dependency Analysis
-- ═══════════════════════════════════════════════════════════════
--
-- Cell graph from r16-synthesis.cell:
--   corpus            → given: program-count ≡ 30, categories[] ≡ [...], §r16-programs
--   pattern-analysis  → given: corpus→feature-usage, corpus→corpus-summary
--   spec-gaps         → given: corpus→feature-usage, pattern-analysis→anti-patterns
--   quality-assessment→ given: §r16-programs, corpus→feature-usage
--   synthesis         → given: pattern-analysis→patterns, pattern-analysis→anti-patterns,
--                              spec-gaps→gaps, spec-gaps→proposals,
--                              quality-assessment→tier-list
--
-- Ready set at h0: { corpus } — all givens are literals or §-refs
-- Blocked: { pattern-analysis, spec-gaps, quality-assessment, synthesis }

-- ═══════════════════════════════════════════════════════════════
-- FRAME 1: eval-one → corpus
-- ═══════════════════════════════════════════════════════════════

⊢ corpus
  given program-count ≡ 30
  given categories[] ≡ [
    "self-evolving (1-5)",
    "adversarial/dialectic (6-10)",
    "recursive decomposition (11-15)",
    "generative/creative (16-20)",
    "validation-heavy (21-25)",
    "meta/self-referential (26-30)"
  ]
  given §r16-programs
  yield corpus-summary, feature-usage[]

  -- ∴ EVALUATION:

  yield corpus-summary ≡ "The R16 corpus contains 30 Cell programs across 6 categories.
    Self-evolving (1-5): Programs that modify their own behavior through ⊢∘ loops —
    research plan evolution, prompt improvement, progressive crystallization,
    self-building test suites, and meta-cell design.
    Adversarial/dialectic (6-10): Multi-agent programs with attacker-defender-judge
    dynamics — spec hardening, recursive debate, red-team/harden cycles,
    negotiation consensus, and Socratic teaching.
    Recursive decomposition (11-15): Programs that recursively break problems into
    sub-problems via ⊢⊢ spawners — fractal planning, requirement extraction,
    progressive summarization, dependency graph building, and recursive explanation.
    Generative/creative (16-20): Programs that generate artifacts through
    evolution — logo evolution, collaborative worldbuilding, recursive story
    construction, code generation with proof, and DSL design.
    Validation-heavy (21-25): Programs with intensive oracle checking — self-correcting
    translation, fact-checked articles, multi-oracle gauntlets, proof-carrying code,
    and oracle chain decomposition.
    Meta/self-referential (26-30): Programs that reason about Cell itself — cell-zero
    execution traces, self-optimization, program algebra proofs, zero-start
    bootstrapping, and spec evolution."

  yield feature-usage[] ≡ [
    -- Program | ⊢ | ⊢= | ⊢⊢ | ⊢∘ | ⊨ | ⊨? | § | ⊥ | «» | cells | notes
    { id: 1,  name: "research-plan-evolver",       soft: 7, hard: 0, spawner: 1, evol: 1, oracle: 16, recovery: 0, quote: 1, bottom: 0, interp: 11, cells: 9,  notes: "⊢∘ evolve(hypothesize), ⊢⊢ spawn-experiments, glob pattern experiment-*" },
    { id: 2,  name: "self-improving-prompt",        soft: 3, hard: 2, spawner: 0, evol: 1, oracle: 5,  recovery: 1, quote: 2, bottom: 0, interp: 5,  cells: 5,  notes: "⊢∘ evolve(summarize), §summarize for prompt rewriting, ⊨? exhaustion" },
    { id: 3,  name: "progressive-crystallization",  soft: 4, hard: 0, spawner: 0, evol: 0, oracle: 13, recovery: 1, quote: 1, bottom: 0, interp: 7,  cells: 6,  notes: "Substrate transfer ⊢→⊢=, verify-crystal, ▸ crystallized output" },
    { id: 4,  name: "self-building-test-suite",     soft: 6, hard: 0, spawner: 1, evol: 1, oracle: 17, recovery: 2, quote: 1, bottom: 0, interp: 10, cells: 8,  notes: "⊢∘ evolve(discover-edge-cases), ⊢⊢ spawn-edge-tests, glob edge-test-*" },
    { id: 5,  name: "meta-cell-designer",           soft: 5, hard: 3, spawner: 0, evol: 1, oracle: 16, recovery: 0, quote: 5, bottom: 0, interp: 8,  cells: 8,  notes: "§program quotation throughout, designs Cell programs, trace-readiness" },
    { id: 6,  name: "spec-hardener",                soft: 3, hard: 1, spawner: 0, evol: 1, oracle: 10, recovery: 1, quote: 2, bottom: 0, interp: 7,  cells: 4,  notes: "Attacker-defender-judge triad, ⊢∘ harden(oracle-spec)" },
    { id: 7,  name: "recursive-debate",             soft: 3, hard: 2, spawner: 0, evol: 1, oracle: 11, recovery: 0, quote: 2, bottom: 0, interp: 6,  cells: 5,  notes: "⊢∘ debate(argue-for, argue-against), multi-target evolution" },
    { id: 8,  name: "red-team-harden",              soft: 4, hard: 0, spawner: 1, evol: 1, oracle: 13, recovery: 1, quote: 1, bottom: 0, interp: 8,  cells: 7,  notes: "Artifact accumulation via regression tests, ⊢⊢ spawn-regression-test" },
    { id: 9,  name: "negotiation-consensus",        soft: 9, hard: 2, spawner: 0, evol: 4, oracle: 15, recovery: 0, quote: 0, bottom: 0, interp: 12, cells: 11, notes: "4 parallel ⊢∘ loops, N-way perspective revision" },
    { id: 10, name: "socratic-teacher",             soft: 5, hard: 3, spawner: 1, evol: 1, oracle: 10, recovery: 0, quote: 1, bottom: 0, interp: 6,  cells: 7,  notes: "⊢∘ teach(ask), ⊢⊢ spawn-remedials, adaptive branching" },
    { id: 11, name: "fractal-task-planner",         soft: 5, hard: 0, spawner: 4, evol: 0, oracle: 16, recovery: 3, quote: 4, bottom: 0, interp: 8,  cells: 11, notes: "4-level fractal: goal→subgoal→task→step→action, 4 ⊢⊢ spawners" },
    { id: 12, name: "recursive-requirement-extractor", soft: 6, hard: 0, spawner: 1, evol: 1, oracle: 14, recovery: 0, quote: 1, bottom: 0, interp: 8, cells: 8, notes: "⊢∘ evolve(extract-implicit), vague→concrete refinement loop" },
    { id: 13, name: "progressive-summarization",    soft: 3, hard: 3, spawner: 1, evol: 0, oracle: 7,  recovery: 1, quote: 0, bottom: 1, interp: 5,  cells: 5,  notes: "⊥ as genuine stop signal, oracle-terminated recursion, halving" },
    { id: 14, name: "dependency-graph-builder",     soft: 4, hard: 0, spawner: 2, evol: 0, oracle: 13, recovery: 1, quote: 2, bottom: 0, interp: 8,  cells: 8,  notes: "Two-level recursive graph: modules + sub-modules, acyclicity oracle" },
    { id: 15, name: "recursive-explanation",        soft: 5, hard: 0, spawner: 1, evol: 1, oracle: 14, recovery: 0, quote: 1, bottom: 0, interp: 8,  cells: 8,  notes: "⊢∘ evolve(explain), comprehension oracle for 10-year-old" },
    { id: 16, name: "evolution-simulator",          soft: 3, hard: 3, spawner: 0, evol: 1, oracle: 9,  recovery: 0, quote: 0, bottom: 0, interp: 5,  cells: 4,  notes: "⊢∘ as genetic algorithm, selection+crossover+mutation" },
    { id: 17, name: "collaborative-world-builder",  soft: 5, hard: 0, spawner: 0, evol: 1, oracle: 13, recovery: 0, quote: 3, bottom: 0, interp: 12, cells: 7,  notes: "Circular deps: geography↔history↔culture, consistency oracle" },
    { id: 18, name: "recursive-story-builder",      soft: 5, hard: 0, spawner: 2, evol: 1, oracle: 13, recovery: 0, quote: 2, bottom: 0, interp: 8,  cells: 9,  notes: "3-level: acts→scenes→beats, bottom-up assembly, ⊢⊢×2" },
    { id: 19, name: "code-generator-with-proof",    soft: 5, hard: 6, spawner: 0, evol: 1, oracle: 14, recovery: 2, quote: 2, bottom: 0, interp: 8,  cells: 8,  notes: "Proof-carrying computation, ⊢= verify-proof, ⊢∘ evolve(generate-code)" },
    { id: 20, name: "language-designer",            soft: 3, hard: 2, spawner: 0, evol: 1, oracle: 12, recovery: 1, quote: 1, bottom: 0, interp: 6,  cells: 5,  notes: "⊢∘ refine(draft-dsl), awkwardness-driven design iteration" },
    { id: 21, name: "self-correcting-translator",   soft: 4, hard: 1, spawner: 0, evol: 1, oracle: 9,  recovery: 1, quote: 0, bottom: 0, interp: 6,  cells: 5,  notes: "⊢∘ refine(translate), back-translation diff oracle" },
    { id: 22, name: "fact-checked-article",         soft: 3, hard: 2, spawner: 1, evol: 1, oracle: 10, recovery: 1, quote: 1, bottom: 0, interp: 6,  cells: 6,  notes: "⊢⊢ spawn per-claim fact-checkers, ⊢∘ fact-check-loop" },
    { id: 23, name: "multi-oracle-gauntlet",        soft: 2, hard: 7, spawner: 0, evol: 1, oracle: 13, recovery: 1, quote: 0, bottom: 0, interp: 4,  cells: 8,  notes: "5 parallel oracles, ⊢= gauntlet aggregator, ⊢∘ refine(explain)" },
    { id: 24, name: "proof-carrying-code",          soft: 4, hard: 6, spawner: 0, evol: 1, oracle: 14, recovery: 2, quote: 2, bottom: 0, interp: 7,  cells: 9,  notes: "Merge sorted lists + correctness proof, ⊢= verify-proof" },
    { id: 25, name: "oracle-chain-builder",         soft: 3, hard: 4, spawner: 2, evol: 1, oracle: 13, recovery: 2, quote: 2, bottom: 0, interp: 6,  cells: 8,  notes: "Soft oracle → deterministic leaves, ⊢⊢ spawn-crystallizers" },
    { id: 26, name: "cell-zero-exerciser",          soft: 5, hard: 12, spawner: 0, evol: 0, oracle: 15, recovery: 0, quote: 5, bottom: 0, interp: 5,  cells: 22, notes: "Metacircular trace, § extensively, 5 eval-one frames, observations" },
    { id: 27, name: "self-optimizing-cell",         soft: 4, hard: 3, spawner: 0, evol: 1, oracle: 10, recovery: 2, quote: 3, bottom: 0, interp: 7,  cells: 7,  notes: "§program-as-data, redundancy analysis, ⊢= compare, semantics preservation" },
    { id: 28, name: "program-algebra-prover",       soft: 3, hard: 10, spawner: 0, evol: 0, oracle: 14, recovery: 2, quote: 3, bottom: 0, interp: 5,  cells: 14, notes: "Dual-program equivalence, confluence demonstration, ⊢= crystallized heavily" },
    { id: 29, name: "bootstrapper",                 soft: 6, hard: 1, spawner: 2, evol: 1, oracle: 14, recovery: 0, quote: 2, bottom: 0, interp: 10, cells: 10, notes: "Zero-start bootstrap, two-phase spawning, ⊢∘ evolve(synthesize)" },
    { id: 30, name: "cell-spec-evolver",            soft: 4, hard: 6, spawner: 0, evol: 1, oracle: 12, recovery: 1, quote: 2, bottom: 0, interp: 5,  cells: 8,  notes: "Cell evolves own spec, conditional dispatch awkwardness, guard clause proposal" }
  ]

  -- ORACLE CHECKS:
  ⊨ feature-usage has 30 entries ✓ (30 entries above)
  ⊨ corpus-summary covers all 6 categories ✓ (self-evolving, adversarial, recursive, generative, validation, meta)

  -- DECISION: all oracles pass → FREEZE corpus

