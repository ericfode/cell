-- --- frame 16: edge-test-9 (century leap year 2000) ---

вҠў edge-test-9
  given edge-input вүЎ "2000-02-29"
  given expected-behavior вүЎ "Date(2000, 2, 29). 2000 IS a leap year."
  given edge-rationale вүЎ "Century leap year вҖ” divisible by 400."
  given function-specвҶ’signature вүЎ "parse_date(s: string) -> Date"
  yield result вүЎ "Date(2000, 2, 29)"
  yield verdict вүЎ "pass"
  yield deeper-edges вүЎ []

-- Clean pass. No deeper edges вҖ” century leap year is well-defined.

-- --- frame 17: edge-test-10 (century non-leap year 1900) ---

вҠў edge-test-10
  given edge-input вүЎ "1900-02-29"
  given expected-behavior вүЎ "ValueError. 1900 is NOT a leap year."
  given edge-rationale вүЎ "Century non-leap year вҖ” divisible by 100, not 400."
  given function-specвҶ’signature вүЎ "parse_date(s: string) -> Date"
  yield result вүЎ "ValueError: February 29 does not exist in 1900 (not a leap year вҖ” divisible by 100 but not 400)"
  yield verdict вүЎ "pass"
  yield deeper-edges вүЎ []

-- --- frame 18: edge-test-11 (day overflow April 31) ---

вҠў edge-test-11
  given edge-input вүЎ "2024-04-31"
  given expected-behavior вүЎ "ValueError. April has 30 days."
  given edge-rationale вүЎ "Day overflow in 30-day month."
  given function-specвҶ’signature вүЎ "parse_date(s: string) -> Date"
  yield result вүЎ "ValueError: Day 31 exceeds maximum of 30 for April"
  yield verdict вүЎ "pass"
  yield deeper-edges вүЎ [
    { input: "2024-06-31", reason: "June also has 30 days вҖ” same edge, different month" }
  ]

-- --- frame 19: edge-test-12 (month zero) ---

вҠў edge-test-12
  given edge-input вүЎ "2024-00-15"
  given expected-behavior вүЎ "ValueError. Month 0 is invalid."
  given edge-rationale вүЎ "Structural vs semantic validity."
  given function-specвҶ’signature вүЎ "parse_date(s: string) -> Date"
  yield result вүЎ "ValueError: Month 0 is not valid (expected 1-12)"
  yield verdict вүЎ "pass"
  yield deeper-edges вүЎ [
    { input: "2024-13-15", reason: "Month 13 вҖ” above range. Same boundary, other side." }
  ]

-- --- frame 20: edge-test-13 (whitespace only) ---

вҠў edge-test-13
  given edge-input вүЎ "   "
  given expected-behavior вүЎ "ValueError. Whitespace-only after trimming is empty."
  given edge-rationale вүЎ "Degenerate input вҖ” spaces only."
  given function-specвҶ’signature вүЎ "parse_date(s: string) -> Date"
  yield result вүЎ "ValueError: empty string after trimming whitespace"
  yield verdict вүЎ "pass"
  yield deeper-edges вүЎ []

-- --- frame 21: edge-test-14 (implicit disambiguation) ---

вҠў edge-test-14
  given edge-input вүЎ "13/01/2024"
  given expected-behavior вүЎ "Date(2024, 1, 13). Month > 12 in US reading forces European interpretation."
  given edge-rationale вүЎ "Implicit disambiguation вҖ” impossible US вҶ’ must be European."
  given function-specвҶ’signature вүЎ "parse_date(s: string) -> Date"
  yield result вүЎ "Date(2024, 1, 13). First number is 13, which exceeds 12, so cannot be a month вҶ’ European DD/MM/YYYY: Day=13, Month=1, Year=2024."
  yield verdict вүЎ "pass"
  yield deeper-edges вүЎ [
    { input: "31/12/2024", reason: "Day 31, Month 12 вҖ” both valid in European. Confirms pattern." }
  ]

-- KEY: This test reveals the implicit disambiguation RULE. When month > 12,
-- the format is forced to European. This is a discoverable spec clarification
-- that emerged from testing, not from reading the spec.

-- --- frame 22: edge-test-15 (reverse relative date) ---

вҠў edge-test-15
  given edge-input вүЎ "last Wednesday"
  given expected-behavior вүЎ "Same ambiguity as 'next Tuesday' вҖ” needs reference date."
  given edge-rationale вүЎ "Relative date, past direction."
  given function-specвҶ’signature вүЎ "parse_date(s: string) -> Date"
  yield result вүЎ "Requires system clock. If today = 2024-03-15 (Friday), last Wednesday = 2024-03-13. But 'last' has the same ambiguity as 'next': if today IS Wednesday, is 'last Wednesday' today or 7 days ago?"
  yield verdict вүЎ "ambiguous"
  yield deeper-edges вүЎ []

-- All iteration 2 edge tests complete.
-- Ready set after frames 16-22: { assess-coverage } (вҠўвҲҳ iteration 2)

