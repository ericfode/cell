-- 25-oracle-chain-builder-frames.cell — full execution trace
--
-- Ready set analysis (initial):
--   api-artifact: ⊢= with no given → READY
--   root-oracle: ⊢= with no given → READY
--   decompose: given root-oracle→text, api-artifact→{endpoints,naming,errors,auth} → BLOCKED
--   spawn-sub-decomposers: given decompose→{sub-oracles,classifications}, api-artifact→* → BLOCKED
--   collect-results: given spawn-sub-decomposers→§refiners, decompose→* → BLOCKED
--   ⊢∘ refine-loop: coordinates iteration over decompose through
--     {spawn-sub-decomposers, collect-results}
--   spawn-crystallizers: given collect-results→* → BLOCKED
--   assemble-hierarchy: given root-oracle→text, collect-results→*, spawn-crystallizers→* → BLOCKED
--   verify-coverage: given assemble-hierarchy→* → BLOCKED
--
-- Ready set: { api-artifact, root-oracle }

-- ═══════════════════════════════════════════════════════════════
-- frame 0: api-artifact (hard cell, deterministic)
-- ═══════════════════════════════════════════════════════════════

⊢ api-artifact
  yield endpoints, naming, errors, auth

  ⊢= endpoints ← "GET /users/{id} → User, POST /users → User, PUT /users/{id} → User, DELETE /users/{id} → 204, GET /users?page=N&limit=M → User[], POST /users/{id}/roles → Role"
  ⊢= naming ← "kebab-case paths, camelCase JSON fields, plural resource nouns"
  ⊢= errors ← "400 {error, message, details[]}, 401 Unauthorized, 403 Forbidden, 404 Not Found, 409 Conflict, 422 Unprocessable Entity, 500 Internal Server Error"
  ⊢= auth ← "Bearer JWT in Authorization header, POST /auth/refresh, scopes: read:users write:users admin:users"

  yield endpoints ≡ "GET /users/{id} → User, POST /users → User, PUT /users/{id} → User, DELETE /users/{id} → 204, GET /users?page=N&limit=M → User[], POST /users/{id}/roles → Role"
  yield naming ≡ "kebab-case paths, camelCase JSON fields, plural resource nouns"
  yield errors ≡ "400 {error, message, details[]}, 401 Unauthorized, 403 Forbidden, 404 Not Found, 409 Conflict, 422 Unprocessable Entity, 500 Internal Server Error"
  yield auth ≡ "Bearer JWT in Authorization header, POST /auth/refresh, scopes: read:users write:users admin:users"

-- No oracles. Deterministic.
-- Ready set after: { root-oracle }

