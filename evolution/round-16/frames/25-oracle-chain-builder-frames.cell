  given api-artifact→naming ≡ "kebab-case paths, camelCase JSON fields, plural resource nouns"
  given api-artifact→errors ≡ "400 {error, message, details[]}, 401 Unauthorized, 403 Forbidden, 404 Not Found, 409 Conflict, 422 Unprocessable Entity, 500 Internal Server Error"
