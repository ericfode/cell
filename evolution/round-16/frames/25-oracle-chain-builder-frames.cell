⊢ root-oracle
  yield text, level

  ⊢= text ← "the API design is good"
  ⊢= level ← 0

  yield text ≡ "the API design is good"
  yield level ≡ 0

-- No oracles. Deterministic.
-- Ready set after: { decompose }

-- ═══════════════════════════════════════════════════════════════
-- frame 2: decompose (soft cell, LLM decomposes vague oracle)
-- ═══════════════════════════════════════════════════════════════

⊢ decompose
  given root-oracle→text ≡ "the API design is good"
  given api-artifact→endpoints ≡ "GET /users/{id} → User, POST /users → User, PUT /users/{id} → User, DELETE /users/{id} → 204, GET /users?page=N&limit=M → User[], POST /users/{id}/roles → Role"
  given api-artifact→naming ≡ "kebab-case paths, camelCase JSON fields, plural resource nouns"
  given api-artifact→errors ≡ "400 {error, message, details[]}, 401 Unauthorized, 403 Forbidden, 404 Not Found, 409 Conflict, 422 Unprocessable Entity, 500 Internal Server Error"
  given api-artifact→auth ≡ "Bearer JWT in Authorization header, POST /auth/refresh, scopes: read:users write:users admin:users"
  yield sub-oracles[], classifications[], soft-count

  ∴ Decompose the vague oracle «root-oracle→text» into 4-6 specific
    sub-oracles by examining the API artifact across these dimensions...

-- LLM evaluation:
-- "the API design is good" is maximally vague. Decomposing across four
-- orthogonal dimensions of API quality. Each dimension maps to a concrete
-- aspect of the artifact.
--
-- 1. "endpoints follow REST conventions" → still vague (what does "REST
--    conventions" mean concretely?) → soft
-- 2. "naming is internally consistent" → still vague (which naming where?) → soft
-- 3. "error responses are comprehensive and structured" → still vague
--    (comprehensive how? structured how?) → soft
-- 4. "authentication uses standard secure patterns" → still vague
--    (which patterns? what's "standard"?) → soft
-- 5. "DELETE returns 204 No Content" → exact value check → deterministic

  yield sub-oracles ≡ [
    "endpoints follow REST conventions for CRUD operations",
    "naming is internally consistent across paths, fields, and resources",
    "error responses are comprehensive and structured",
    "authentication uses standard secure token patterns",
    "DELETE endpoint returns 204 status code"
  ]
  yield classifications ≡ ["soft", "soft", "soft", "soft", "deterministic"]
  yield soft-count ≡ 4

-- oracle checks:
--   ⊨ length(sub-oracles) ≥ 4 → ✓ (5 sub-oracles)
--   ⊨ length(sub-oracles) ≤ 6 → ✓ (5 ≤ 6)
--   ⊨ length(classifications) = length(sub-oracles) → ✓ (5 = 5)
--   ⊨ each classification ∈ {"soft", "structural", "deterministic"} → ✓
--   ⊨ soft-count = count of "soft" in classifications → ✓ (4 soft entries)
--
-- All oracles pass. Freeze output.
-- Ready set after: { spawn-sub-decomposers }

