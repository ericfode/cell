-- ═══════════════════════════════════════════════════════════════

⊢ decomposer-3
  given requirement ≡ "R-I7: The app works on mobile devices — platforms unspecified."
  yield sub-requirements[], all-concrete

-- LLM evaluation (simulated):

  yield sub-requirements ≡ [
    "R-I7a: The app runs as a responsive web application accessible via mobile browsers (Safari iOS 15+, Chrome Android 10+).",
    "R-I7b: The UI adapts to screen widths from 320px to 428px (standard phone range).",
