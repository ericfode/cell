-- ═══════════════════════════════════════════════════════════════

⊢ decomposer-4
  given requirement ≡ "R-I8: Users receive notifications — trigger conditions unspecified."
  yield sub-requirements[], all-concrete

-- LLM evaluation (simulated):

  yield sub-requirements ≡ [
    "R-I8a: Users receive browser push notifications for new messages when the app tab is not in focus.",
    "R-I8b: Notifications display the sender name and first 50 characters of the message.",
    "R-I8c: Users can mute notifications per-conversation.",
