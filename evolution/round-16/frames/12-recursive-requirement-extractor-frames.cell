-- oracle checks: ✓ (specific triggers, content, controls, timing)

-- ═══════════════════════════════════════════════════════════════
-- FRAME 10: evaluate decomposer-5 (disconnection handling)
-- ═══════════════════════════════════════════════════════════════

⊢ decomposer-5
  given requirement ≡ "R-I9: Handles disconnection gracefully — 'gracefully' undefined."
  yield sub-requirements[], all-concrete

-- LLM evaluation (simulated):

  yield sub-requirements ≡ [
    "R-I9a: When connection is lost, a visible 'offline' banner appears within 3 seconds.",
    "R-I9b: Messages composed while offline are queued locally and sent automatically on reconnection.",
    "R-I9c: The app attempts reconnection every 5 seconds, with exponential backoff up to 60 seconds.",
    "R-I9d: On reconnection, missed messages are fetched and displayed in correct chronological order.",
    "R-I9e: No user data is lost during a disconnection of up to 24 hours."
  ]

  yield all-concrete ≡ true

-- oracle checks: ✓ (specific behaviors, timing, guarantees)

-- state after frames 5-10: all decomposer cells frozen.
