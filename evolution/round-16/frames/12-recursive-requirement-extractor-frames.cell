-- FRAME 11: evaluate collect-requirements (soft cell, LLM)
-- ═══════════════════════════════════════════════════════════════

⊢ collect-requirements
  given assess-concreteness→concrete ≡ ["R-E1...", "R-E2...", "R-E3...", "R-E4...", "R-I1...", "R-I2...", "R-I4..."]
  given decomposer-0→sub-requirements ≡ ["R-I3a...", "R-I3b...", "R-I3c..."]
  given decomposer-0→all-concrete ≡ true
  given decomposer-1→sub-requirements ≡ ["R-I5a...", "R-I5b...", "R-I5c...", "R-I5d..."]
  given decomposer-1→all-concrete ≡ true
  given decomposer-2→sub-requirements ≡ ["R-I6a...", "R-I6b...", "R-I6c...", "R-I6d..."]
  given decomposer-2→all-concrete ≡ true
  given decomposer-3→sub-requirements ≡ ["R-I7a...", "R-I7b...", "R-I7c...", "R-I7d..."]
  given decomposer-3→all-concrete ≡ true
  given decomposer-4→sub-requirements ≡ ["R-I8a...", "R-I8b...", "R-I8c...", "R-I8d...", "R-I8e..."]
  given decomposer-4→all-concrete ≡ true
  given decomposer-5→sub-requirements ≡ ["R-I9a...", "R-I9b...", "R-I9c...", "R-I9d...", "R-I9e..."]
  given decomposer-5→all-concrete ≡ true
  yield all-requirements[], remaining-vague[], completeness-score

-- LLM evaluation (simulated):

  yield all-requirements ≡ [
    "R-E1: The system is a software application.",
    "R-E2: The application supports chat — sending and receiving text messages.",
    "R-E3: Built from scratch.",
    "R-E4: Requester is owner/stakeholder.",
