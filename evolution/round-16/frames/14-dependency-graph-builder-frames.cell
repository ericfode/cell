-- --- frame 17: sub-analyzer-5 (gt internals) ---

⊢ sub-analyzer-5
  given module-name ≡ "gt"
  given module-deps ≡ ["beads", "mayor", "witness"]
  yield sub-modules[], sub-edges[], sub-is-acyclic

  yield sub-modules ≡ ["command-parser", "session-manager", "mail-client"]
  yield sub-edges ≡ [
