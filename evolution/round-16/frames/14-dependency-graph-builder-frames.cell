⊢ sub-analyzer-1
  given module-name ≡ "mayor"
  given module-deps ≡ ["beads", "dolt", "witness"]
  yield sub-modules[], sub-edges[], sub-is-acyclic

  ∴ Decompose mayor into 2-4 internal sub-modules...

  yield sub-modules ≡ ["dispatcher", "escalation-handler", "state-manager"]
  yield sub-edges ≡ [
    { source: "dispatcher", target: "state-manager" },
    { source: "escalation-handler", target: "state-manager" },
    { source: "dispatcher", target: "escalation-handler" }
  ]
  yield sub-is-acyclic ≡ true

-- Mayor internals: dispatcher → escalation-handler → state-manager.
-- Clean DAG. No cycles within mayor.

