-- --- frame 16: sub-analyzer-4 (beads internals) ---

⊢ sub-analyzer-4
  given module-name ≡ "beads"
  given module-deps ≡ ["dolt"]
  yield sub-modules[], sub-edges[], sub-is-acyclic

  yield sub-modules ≡ ["issue-store", "dependency-engine", "routing"]
  yield sub-edges ≡ [
