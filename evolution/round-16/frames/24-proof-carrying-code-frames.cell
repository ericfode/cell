-- ═══════════════════════════════════════════════════════════════
-- FRAME 5: evaluate verify-proof (⊢= crystallized — deterministic check)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { verify-proof }
-- P-time structural verification. No LLM needed.
-- This is the proof-carrying computation pattern in action.

⊢ verify-proof ▸ crystallized
  given generate-proof→proof-argument ≡ "THEOREM: merge_sorted..."
  given generate-proof→invariants ≡ [INV1, INV2, INV3]
  given generate-proof→termination-argument ≡ "i + j increases by 1..."
  given generate-proof→properties-proved ≡ ["sortedness", "permutation", "termination", "length-preservation"]
  given generate-code→code-text ≡ "def merge_sorted(a, b): ..."
  yield proof-valid, gaps[], verdict

  ⊢= proof-valid ← (
    has-loop-invariant(invariants) ∧            -- ✓ INV1 is a loop invariant
    invariant-references(invariants, ["i", "j", "result"]) ∧  -- ✓ INV1 refs all three
    has-monotone-quantity(termination-argument) ∧  -- ✓ "i + j increases by 1"
    has-upper-bound(termination-argument) ∧     -- ✓ "bounded by len(a) + len(b)"
    proof-covers(proof-argument, ["sortedness", "permutation", "termination"]) ∧  -- ✓ steps 2, 3, 4
    proof-uses-precondition(proof-argument, "sorted")  -- ✓ step 6
  )
  -- All conjuncts true:

  yield proof-valid ≡ true

  ⊢= gaps ← missing-from(proof-argument, [
    "loop-invariant",              -- present (step 1, INV1)
    "sortedness-preservation",     -- present (step 2)
    "permutation",                 -- present (step 3)
    "termination",                 -- present (step 4)
    "postcondition-discharge"      -- present (step 5)
  ])
  -- All required components present:

  yield gaps ≡ []

  ⊢= verdict ← proof-valid ∧ gaps = [] → "proof complete"

  yield verdict ≡ "proof complete"

-- oracle checks:
--   ⊨ verdict ∈ valid set → ✓ ("proof complete")
--   ⊨ proof-valid → gaps has at most 1 element → ✓ (gaps = [])
--   ⊨ not proof-valid → gaps ≥ 2 → ✓ (vacuous — proof-valid is true)

-- KEY MOMENT: The crystallized verifier (⊢=) checked the LLM-generated proof
-- WITHOUT calling the LLM. Pure structural verification in P-time.
-- The ⊢∘ evolution loop checks: verdict = "proof complete"? YES.
-- ⊢∘ CONVERGES after iteration 1 — proof was complete on first generation.

-- state after frame 5: verify-proof frozen.
