  yield proof-patch ≡ "none"
  yield patched-steps ≡ []

-- oracle checks:
--   ⊨ verdict = "proof complete" → proof-patch = "none" → ✓
--   ⊨ verdict ≠ "proof complete" → patched-steps covers gaps → ✓ (vacuous)
--   ⊨ each patched-step references its gap → ✓ (vacuous — no steps)

