-- FRAME 7: evaluate assemble-certificate (soft cell, LLM — assembly)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { assemble-certificate }
-- Final deliverable: code + proof + evidence bundled together.

⊢ assemble-certificate
  given generate-code→code-text ≡ "def merge_sorted(a, b): ..."
  given fill-gaps→proof-patch ≡ "none"
  given generate-proof→proof-argument ≡ "THEOREM: merge_sorted..."
  given generate-proof→properties-proved ≡ ["sortedness", "permutation", "termination", "length-preservation"]
  given verify-proof→verdict ≡ "proof complete"
  given verify-proof→gaps ≡ []
  given run-tests→pass-count ≡ 14
  yield certificate, confidence-level

  ∴ Assemble proof-carrying certificate...

-- LLM evaluation (simulated):

  yield certificate ≡ "
    ╔══════════════════════════════════════════════════════════════╗
    ║  PROOF-CARRYING CERTIFICATE                                  ║
    ║  merge_sorted(a: int[], b: int[]) -> int[]                   ║
    ╠══════════════════════════════════════════════════════════════╣
    ║                                                              ║
    ║  CODE (verified):                                            ║
    ║    def merge_sorted(a, b):                                   ║
    ║      result, i, j = [], 0, 0                                 ║
    ║      while i < len(a) and j < len(b):                        ║
    ║        if a[i] <= b[j]: result.append(a[i]); i += 1         ║
    ║        else: result.append(b[j]); j += 1                    ║
    ║      result += a[i:] + b[j:]                                 ║
    ║      return result                                           ║
    ║                                                              ║
    ║  TESTS: 14/14 passing                                        ║
    ║    Properties: sorted-output, permutation, length,           ║
    ║    empty-left, empty-right, both-empty, interleaved,         ║
    ║    duplicates                                                ║
    ║                                                              ║
    ║  PROOF: 6-step correctness argument                          ║
