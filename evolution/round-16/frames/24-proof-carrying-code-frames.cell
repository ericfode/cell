-- Picking generate-code first (primary output of the program)

⊢ generate-code
  given spec→description ≡ "merge two sorted lists into one sorted list"
  given spec→signature ≡ "merge_sorted(a: int[], b: int[]) -> int[]"
  given spec→preconditions ≡ "a is sorted ascending, b is sorted ascending"
  yield §implementation, code-text

  ∴ Write a correct two-pointer merge implementation...

-- LLM evaluation (simulated):

  yield §implementation ≡ §merge-sorted-v1
  yield code-text ≡ "
    def merge_sorted(a: int[], b: int[]) -> int[]:
      result = []
      i = 0
      j = 0
      while i < len(a) and j < len(b):
        if a[i] <= b[j]:
          result.append(a[i])
          i += 1
        else:
          result.append(b[j])
          j += 1
      while i < len(a):
        result.append(a[i])
        i += 1
      while j < len(b):
        result.append(b[j])
        j += 1
      return result
  "

-- oracle checks:
--   ⊨ code-text contains a loop or iterative structure → ✓ (three while loops)
--   ⊨ code-text compares elements from both lists → ✓ (a[i] <= b[j])
--   ⊨ code-text handles exhaustion of either list → ✓ (two trailing while loops)

