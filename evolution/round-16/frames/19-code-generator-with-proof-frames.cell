⊢ generate-code
  given spec→description ≡ "binary search on sorted array, returns index or -1"
  given spec→signature ≡ "binary_search(arr: int[], target: int) -> int"
  given spec→preconditions ≡ "arr is sorted in ascending order, no duplicates"
  yield §implementation, code-text

  ∴ Write a correct implementation of binary_search(arr, target)...

-- LLM evaluation (simulated):

  yield §implementation ≡ §binary-search-v1
  yield code-text ≡ "
    def binary_search(arr: int[], target: int) -> int:
      lo = 0
      hi = len(arr) - 1
      while lo <= hi:
        mid = lo + (hi - lo) // 2
        if arr[mid] == target:
          return mid
        elif arr[mid] < target:
          lo = mid + 1
        else:
          hi = mid - 1
      return -1
  "

-- oracle checks:
--   ⊨ code-text contains a loop structure → ✓ (while lo <= hi)
--   ⊨ code-text returns -1 for not-found → ✓ (return -1 at end)
--   ⊨ code-text uses integer division for midpoint → ✓ (lo + (hi - lo) // 2)

