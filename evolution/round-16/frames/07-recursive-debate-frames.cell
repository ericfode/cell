  given §argue-for ≡ "(v1 definition)"
  given §argue-against ≡ "(v2 definition)"
  given judge-round→weakest-side ≡ "for"
  given judge-round→weakest-claim ≡ "Fiduciary trust..."
  given judge-round→feedback ≡ "Address naive fiduciary rebuttal. Propose structural safeguards..."
  yield §argue-for', §argue-against'

