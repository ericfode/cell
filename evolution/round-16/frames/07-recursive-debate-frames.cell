  -- (same ∴ as v2, same inputs → same output)
  yield argument ≡ "(same as v2 — info asymmetry, naive fiduciary, consent boundary)"
  yield key-claims ≡ ["info asymmetry", "naive fiduciary", "statelessness is consent boundary"]

