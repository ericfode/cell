  ∴ Test the patched code...

-- LLM evaluation:
-- 1. Exploit test: login('nonexistent_user', 'anything')
--    → users.get('nonexistent_user') → None
--    → None is not None → False → skip
--    → return None
--    No KeyError! Same response as wrong password. ✓ Exploit blocked.
--
-- 2. Regression tests: none yet (first iteration).
--
-- 3. New issues: The `stored_password == password` comparison is still
--    plaintext. And `is not None` means a user with password "" (empty string)
--    would fail even with correct password... wait, no. get() returns ""
--    which is not None, then "" == "" → True. Fine.
--    But what about a user whose stored password is None? Unlikely but
--    theoretically: users["ghost"] = None → get returns None → is not None
--    fails → can never log in. Edge case but not a security issue.

  yield exploit-blocked ≡ true
  yield regressions-pass ≡ true
  yield new-issues ≡ ["Plaintext password comparison still present (separate vulnerability, not introduced by this patch)"]

