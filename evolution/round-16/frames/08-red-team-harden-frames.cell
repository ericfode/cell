-- LLM evaluation:
-- Replace `stored_password == password` with hash comparison.
-- Use bcrypt (industry standard). Assume users dict now stores hashed passwords.
-- Must still handle missing users (regression-test-1).

  yield patched-code ≡ "import bcrypt

def login(username, password):
    stored_hash = users.get(username)
    if stored_hash is not None and bcrypt.checkpw(password.encode('utf-8'), stored_hash):
        return create_session(username)
    return None"

  yield patch-description ≡ "Replaced plaintext == comparison with bcrypt.checkpw(). Assumes users dict stores bcrypt hashes instead of plain passwords. bcrypt handles salt internally. Preserved .get() pattern from iteration 1 — regression-test-1 still passes."

-- oracle checks:
--   ⊨ patched-code is valid Python → ✓
--   ⊨ patched-code fixes the vulnerability → ✓ (bcrypt hash comparison)
--   ⊨ preserves correct login behavior → ✓ (valid credentials still work)

-- KEY: The patch CHANGED THE CONTRACT. `users` dict now stores hashes, not
-- plaintext. This is a migration issue the patch description should flag.
-- But the code itself is correct.

