-- frame 8: validate-level-2
-- ═══════════════════════════════════════════════════════════════

⊢ validate-level-2
  given task-decomposer-1→tasks ≡ [T1.1, T1.2, T1.3, T1.4]
  given task-decomposer-2→tasks ≡ [T2.1, T2.2, T2.3, T2.4]
  given task-decomposer-3→tasks ≡ [T3.1, T3.2, T3.3]
  given task-decomposer-4→tasks ≡ [T4.1, T4.2, T4.3, T4.4]
  given decompose-goal→sub-goals ≡ [SG1, SG2, SG3, SG4]
  yield valid, cross-cutting-issues[]

  ∴ Validate ALL task decompositions together...

-- LLM evaluation:
-- Cross-cutting analysis across all 15 tasks:
--
-- 1. T1.2 (invoice API) and T3.1 (Stripe) — invoices need payment status
--    from Stripe. Hidden dependency: T3.1 must provide payment webhook
--    BEFORE T1.2 can mark invoices as paid. Not a conflict, but a
--    sequencing constraint.
--
-- 2. T2.1 (cloud infra) is a prerequisite for EVERYTHING. Must be first.
--    Not flagged as a cross-cutting issue — it's a natural dependency.
--
-- 3. T4.2 (onboarding) depends on T1.2 (invoice CRUD) and T3.2 (plans).
--    The onboarding wizard creates the first invoice and selects a plan.
--    Hidden cross-subgoal dependency.
--
-- 4. No actual OVERLAP detected. Each task lives in exactly one subgoal.

  yield valid ≡ true
  yield cross-cutting-issues ≡ [
    "DEPENDENCY (not overlap): T4.2 (onboarding) requires T1.2 (invoice API) + T3.2 (subscription plans). Schedule accordingly.",
    "DEPENDENCY: T1.2 (mark as paid) needs T3.1 (Stripe webhooks) for payment confirmation."
  ]

-- oracle checks:
--   ⊨ valid ∈ { true, false } → ✓ (true)
--   ⊨ cross-cutting-issues identifies conflicts → ✓ (dependencies noted, not conflicts)

-- LEVEL 2 PASSES. Dependencies noted but no MECE violations.
