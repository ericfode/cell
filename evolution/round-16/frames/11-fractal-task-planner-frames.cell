-- 11-fractal-task-planner-frames.cell — full eval-one execution trace
--
-- Ready set analysis:
--   goal: all givens have ≡ → READY
--   decompose-goal: needs goal→statement → BLOCKED
--   validate-level-1: needs decompose-goal→sub-goals → BLOCKED
--   spawn-task-decomposers: needs decompose-goal→sub-goals → BLOCKED
--   task-decomposer-*: spawned dynamically → BLOCKED
--   validate-level-2: needs task-decomposer-*→tasks → BLOCKED
--   spawn-step-decomposers: needs task-decomposer-*→tasks → BLOCKED
--   step-decomposer-*: spawned dynamically → BLOCKED
--   validate-level-3: needs step-decomposer-*→steps → BLOCKED
--   spawn-action-decomposers: needs step-decomposer-*→steps → BLOCKED
--   action-decomposer-*: spawned dynamically → BLOCKED
--   validate-level-4: needs action-decomposer-*→actions → BLOCKED
--   assemble-plan: needs everything → BLOCKED
--
-- Ready set: { goal }
--
-- Structure: LINEAR spine with FAN-OUT at each level.
--   goal → decompose-goal → validate-level-1 → spawn-task-decomposers
--     → [task-decomposer-1..N] → validate-level-2 → spawn-step-decomposers
--       → [step-decomposer-1..M] → validate-level-3 → spawn-action-decomposers
--         → [action-decomposer-1..K] → validate-level-4 → assemble-plan
--
-- The fractal repeats: decompose → validate → spawn → (next level).

-- ═══════════════════════════════════════════════════════════════
-- frame 0: goal
-- ═══════════════════════════════════════════════════════════════

⊢ goal
  given statement ≡ "Launch a SaaS product for small business invoicing in 3 months"
  given max-depth ≡ 4
  yield statement ≡ "Launch a SaaS product for small business invoicing in 3 months"
  yield max-depth ≡ 4

  ⊨ statement is a concrete, achievable goal with a timeline → ✓
  ⊨ max-depth ≥ 3 → ✓ (4)

-- Ready set after frame 0: { decompose-goal }

-- ═══════════════════════════════════════════════════════════════
-- LEVEL 1: Goal → Sub-goals
-- ═══════════════════════════════════════════════════════════════

-- ═══════════════════════════════════════════════════════════════
-- frame 1: decompose-goal
-- ═══════════════════════════════════════════════════════════════

⊢ decompose-goal
  given goal→statement ≡ "Launch a SaaS product for small business invoicing in 3 months"
  yield sub-goals[], rationale

  ∴ Decompose the goal into 3-5 sub-goals (MECE)...

-- LLM evaluation:
-- "Launch a SaaS product" breaks into: build it, make it legally compliant,
-- get customers, run the infrastructure, and handle payments. Let me make
-- these MECE (mutually exclusive, collectively exhaustive).

  yield sub-goals ≡ [
    "SG1: Build the core invoicing application (create, send, track invoices; manage clients; dashboard)",
    "SG2: Set up infrastructure and operations (hosting, CI/CD, monitoring, security, backups)",
    "SG3: Implement billing and payments integration (Stripe/payment processor, subscription plans, free trial)",
    "SG4: Launch go-to-market (landing page, onboarding flow, documentation, initial marketing)"
  ]

  yield rationale ≡ "4 sub-goals covering: product (SG1), platform (SG2), monetization (SG3), distribution (SG4). MECE check: SG1 = what it does, SG2 = where it runs, SG3 = how it earns, SG4 = how users find it. No overlap: billing UI is in SG1, payment processing is in SG3. Legal/compliance folded into SG2 (security) and SG3 (payment compliance)."

-- oracle checks:
--   ⊨ 3 ≤ length(sub-goals) ≤ 5 → ✓ (4)
--   ⊨ each sub-goal is necessary → ✓ (can't launch without any of these)
--   ⊨ sub-goals are non-overlapping (MECE) → ✓ (product/platform/money/distribution)
--   ⊨ sub-goals collectively cover full scope → ✓

-- Ready set after frame 1: { validate-level-1 }

-- ═══════════════════════════════════════════════════════════════
-- frame 2: validate-level-1
-- ═══════════════════════════════════════════════════════════════

⊢ validate-level-1
  given decompose-goal→sub-goals ≡ [SG1: core app, SG2: infrastructure, SG3: billing, SG4: go-to-market]
  given goal→statement ≡ "Launch a SaaS product for small business invoicing in 3 months"
  yield valid, issues[]

  ∴ Validate the decomposition...

-- LLM evaluation:
-- 1. COMPLETENESS: product ✓, infra ✓, billing ✓, marketing ✓.
--    Missing? Legal entity formation? → implicit in SG3 (payment requires business entity).
--    Customer support? → implicit in SG4 (onboarding/docs).
--    Acceptable — 3-month MVP doesn't need a support team.
--
-- 2. NON-OVERLAP: SG1 (product features) vs SG3 (payment integration) — billing UI
--    is in SG1, payment processing in SG3. Clean boundary. ✓
--
-- 3. GRANULARITY: each sub-goal is 2-4 weeks of work. Right level. ✓
--
-- 4. FEASIBILITY: 4 sub-goals × ~3 weeks each = 12 weeks = 3 months.
--    Some parallelism possible (SG2 can start immediately, SG4 last). ✓

  yield valid ≡ true
  yield issues ≡ []

-- oracle checks:
--   ⊨ valid ∈ { true, false } → ✓ (true)
--   ⊨ if not valid then issues non-empty → N/A (valid)

-- LEVEL 1 PASSES. No ⊥, no retry needed. Proceed to Level 2.
-- Ready set after frame 2: { spawn-task-decomposers }

-- ═══════════════════════════════════════════════════════════════
-- LEVEL 2: Sub-goals → Tasks
-- ═══════════════════════════════════════════════════════════════

-- ═══════════════════════════════════════════════════════════════
-- frame 3: spawn-task-decomposers
-- ═══════════════════════════════════════════════════════════════

⊢⊢ spawn-task-decomposers
  given decompose-goal→sub-goals ≡ [SG1, SG2, SG3, SG4]
  given §task-decomposer-template
  yield §task-decomposer-cells ≡ [§task-decomposer-1, §task-decomposer-2, §task-decomposer-3, §task-decomposer-4]

  ⊨ one task-decomposer cell per sub-goal → ✓ (4 cells for 4 sub-goals)

-- 4 cells spawned. All immediately READY (each has its sub-goal bound).
-- Ready set after frame 3: { task-decomposer-1, task-decomposer-2, task-decomposer-3, task-decomposer-4 }
-- FAN-OUT: 4 parallel-eligible cells. Confluence guarantees order doesn't matter.

