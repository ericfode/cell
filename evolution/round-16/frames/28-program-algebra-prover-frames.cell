⊢ compare-execution-order
  given trace-A→frames-A ≡ [
    { step: 0, cell: "input-data", ... },
    { step: 1, cell: "weighted-sum-A", ... },
    { step: 2, cell: "total-weight-A", ... },
    { step: 3, cell: "weighted-average-A", ... }
  ]
  given trace-B→frames-B ≡ [
    { step: 0, cell: "input-data", ... },
    { step: 1, cell: "total-weight-B", ... },
    { step: 2, cell: "weighted-sum-B", ... },
    { step: 3, cell: "weighted-average-B", ... }
  ]
  yield order-differs, shared-steps[], divergence-point

  ∴ Compare step-by-step execution order...

-- LLM evaluation (simulated):
-- Step 0: A="input-data",     B="input-data"      → SAME (shared)
-- Step 1: A="weighted-sum-A", B="total-weight-B"   → DIFFERENT (divergence!)
-- Step 2: A="total-weight-A", B="weighted-sum-B"   → DIFFERENT (swapped)
-- Step 3: A="weighted-average-A", B="weighted-average-B" → structurally same (final step)

  yield order-differs ≡ true
  yield shared-steps ≡ [
    { step: 0, cell-A: "input-data", cell-B: "input-data", note: "identical first step" }
  ]
  yield divergence-point ≡ 1

-- oracle checks:
--   ⊨ order-differs = true → ✓ (step 1 differs)
--   ⊨ divergence-point ≤ length(frames-A) → ✓ (1 ≤ 4)
--   ⊨ length(shared-steps) < length(frames-A) → ✓ (1 < 4)

