-- ═══════════════════════════════════════════════════════════════
-- Ready set: { trace-A, trace-B }
-- Picking trace-A first.

⊢ trace-A
  given program-A→execution-order-A ≡ ["input-data", "weighted-sum-A", "total-weight-A", "weighted-average-A"]
  given input-data→values ≡ [10, 20, 30, 40]
  given input-data→weights ≡ [1, 2, 3, 4]
  yield frames-A[], final-state-A

  ∴ Execute program A step by step...

-- LLM evaluation (simulated):

  yield frames-A ≡ [
    { step: 0, cell: "input-data",        inputs: { values: [10,20,30,40], weights: [1,2,3,4] },
      yields: { values: [10,20,30,40], weights: [1,2,3,4] }, oracles: ["✓","✓","✓"] },
    { step: 1, cell: "weighted-sum-A",    inputs: { values: [10,20,30,40], weights: [1,2,3,4] },
      yields: { weighted-sum: 300 },       oracles: ["✓"] },
    { step: 2, cell: "total-weight-A",    inputs: { weights: [1,2,3,4] },
      yields: { total-weight: 10 },        oracles: ["✓"] },
    { step: 3, cell: "weighted-average-A", inputs: { weighted-sum: 300, total-weight: 10 },
      yields: { average: 30 },             oracles: ["✓"] }
  ]

  yield final-state-A ≡ {
    "input-data→values": [10, 20, 30, 40],
    "input-data→weights": [1, 2, 3, 4],
    "weighted-sum-A→weighted-sum": 300,
    "total-weight-A→total-weight": 10,
    "weighted-average-A→average": 30
  }

-- oracle checks:
--   ⊨ length(frames-A) = length(execution-order-A) → ✓ (4 = 4)
--   ⊨ final-state-A includes weighted-average-A→average → ✓ (30)

