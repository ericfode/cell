-- ═══════════════════════════════════════════════════════════════
-- FRAME 11: evaluate build-correspondence (crystallized, deterministic)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { build-correspondence, compare-execution-order }
-- Picking build-correspondence (feeds into generate-proof)

⊢ build-correspondence ▸ crystallized
  given trace-A→final-state-A ≡ { ..., "weighted-sum-A→weighted-sum": 300, "total-weight-A→total-weight": 10, "weighted-average-A→average": 30 }
  given trace-B→final-state-B ≡ { ..., "total-weight-B→total-weight": 10, "weighted-sum-B→weighted-sum": 300, "weighted-average-B→average": 30 }
  yield correspondence[], matched-count, unmatched[]

  ⊢= correspondence ← [...]
  ⊢= matched-count ← count(...)
  ⊢= unmatched ← [...]

-- deterministic evaluation:
--   correspondence[0]: weighted-sum-A(300) vs weighted-sum-B(300) → match: true
--   correspondence[1]: total-weight-A(10) vs total-weight-B(10) → match: true
--   correspondence[2]: weighted-average-A(30) vs weighted-average-B(30) → match: true

  yield correspondence ≡ [
    { cell-A: "weighted-sum-A",     cell-B: "weighted-sum-B",     field: "weighted-sum", match: true },
    { cell-A: "total-weight-A",     cell-B: "total-weight-B",     field: "total-weight", match: true },
    { cell-A: "weighted-average-A", cell-B: "weighted-average-B", field: "average",      match: true }
  ]
