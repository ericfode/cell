-- FRAME 15: evaluate equivalence-certificate (soft cell, LLM)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { equivalence-certificate }

⊢ equivalence-certificate
  given verify-proof→verdict ≡ "equivalence proved"
  given verify-proof→proof-valid ≡ true
  given verify-proof→gaps ≡ []
  given generate-proof→proof-argument ≡ "Programs A and B compute the weighted average ... are provably equivalent."
  given build-correspondence→correspondence ≡ [{ ..., match: true }, { ..., match: true }, { ..., match: true }]
  given compare-execution-order→order-differs ≡ true
  given weighted-average-A→average ≡ 30
  given weighted-average-B→average ≡ 30
  yield certificate, equivalence-status, confidence

  ∴ Assemble the final equivalence certificate...

-- LLM evaluation (simulated):

  yield certificate ≡ "
    ╔══════════════════════════════════════════════════════════╗
    ║         PROGRAM EQUIVALENCE CERTIFICATE                 ║
    ╠══════════════════════════════════════════════════════════╣
    ║                                                         ║
    ║  Programs compared:                                     ║
    ║    A: sum-first (weighted-sum → total-weight → avg)     ║
