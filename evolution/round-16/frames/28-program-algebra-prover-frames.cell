⊢ verify-proof ▸ crystallized
  given generate-proof→proof-steps ≡ [{ name: "dependency-isomorphism", ... }, { name: "cell-equivalence", ... }, { name: "confluence-application", ... }]
  given generate-proof→proof-technique ≡ "structural induction on dependency graph + confluence theorem"
  given build-correspondence→matched-count ≡ 3
  given build-correspondence→unmatched ≡ []
  given compare-execution-order→order-differs ≡ true
  yield proof-valid, gaps[], verdict

  ⊢= proof-valid ← (
    length(proof-steps) ≥ 3 ∧           -- ✓ 3 ≥ 3
    proof-technique contains "confluence" ∧  -- ✓ "confluence theorem"
    matched-count = 3 ∧                  -- ✓ 3 = 3
    length(unmatched) = 0 ∧              -- ✓ 0 = 0
    order-differs = true                 -- ✓ true = true
  )

-- deterministic evaluation:
--   all conjuncts true → proof-valid = true

  ⊢= gaps ← missing-from(proof-steps, [
    "dependency-isomorphism", "cell-equivalence", "confluence-application"
  ])

-- deterministic evaluation:
--   proof-steps contains all three required names → gaps = []

  ⊢= verdict ← if proof-valid ∧ gaps = [] then "equivalence proved"
                else ...

-- deterministic evaluation:
--   proof-valid = true, gaps = [] → verdict = "equivalence proved"

  yield proof-valid ≡ true
  yield gaps ≡ []
  yield verdict ≡ "equivalence proved"

-- oracle checks:
--   ⊨ verdict ∈ {"equivalence proved", ...} → ✓
--   ⊨ if proof-valid then length(gaps) ≤ 1 → ✓ (0 ≤ 1)

