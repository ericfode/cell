-- 28-program-algebra-prover-frames.cell
-- Execution trace of 28-program-algebra-prover.cell via eval-one
--
-- Spec: Two equivalent programs (weighted average via different execution
-- orders). Trace both, compare outputs, prove equivalence using confluence.
--
-- Key insight demonstrated: Cell's confluence property guarantees that
-- independent cells can execute in any order and produce identical results.
-- This trace makes it concrete by running both orderings.

-- ═══════════════════════════════════════════════════════════════
-- FRAME 0: evaluate input-data (trivial pass-through)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { input-data }
-- Blocked: { program-A, program-B, weighted-sum-A, total-weight-A,
--            weighted-sum-B, total-weight-B, trace-A, trace-B, ... }
-- All downstream cells need input-data→values or input-data→weights.

⊢ input-data
  given values ≡ [10, 20, 30, 40]
  given weights ≡ [1, 2, 3, 4]
  yield values, weights

  yield values ≡ [10, 20, 30, 40]
  yield weights ≡ [1, 2, 3, 4]

-- oracle checks:
--   ⊨ length(values) = length(weights) → ✓ (4 = 4)
--   ⊨ length(values) ≥ 1 → ✓ (4 ≥ 1)
--   ⊨ all elements of weights are positive → ✓ (1, 2, 3, 4 all > 0)

-- state after frame 0: input-data frozen.
-- Ready set: { weighted-sum-A, total-weight-A, weighted-sum-B, total-weight-B }
-- The four computation cells are now unblocked (all depend only on input-data).
-- program-A and program-B remain blocked on §-references.

-- ═══════════════════════════════════════════════════════════════
-- FRAME 1: evaluate weighted-sum-A (crystallized, deterministic)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { weighted-sum-A, total-weight-A, weighted-sum-B, total-weight-B }
-- Picking weighted-sum-A (program A: sum-first ordering)

⊢ weighted-sum-A ▸ crystallized
  given input-data→values ≡ [10, 20, 30, 40]
  given input-data→weights ≡ [1, 2, 3, 4]
  yield weighted-sum

  ⊢= weighted-sum ← sum(values[i] * weights[i] for i in 0..length(values))

-- deterministic evaluation:
--   values[0] * weights[0] = 10 * 1  = 10
--   values[1] * weights[1] = 20 * 2  = 40
--   values[2] * weights[2] = 30 * 3  = 90
--   values[3] * weights[3] = 40 * 4  = 160
--   sum = 10 + 40 + 90 + 160 = 300

  yield weighted-sum ≡ 300

-- oracle checks:
--   ⊨ weighted-sum = 10*1 + 20*2 + 30*3 + 40*4 = 300 → ✓ (300 = 300)

-- state after frame 1: weighted-sum-A frozen.
-- Ready set: { total-weight-A, weighted-sum-B, total-weight-B }
-- weighted-average-A still blocked (needs total-weight-A→total-weight)

-- ═══════════════════════════════════════════════════════════════
-- FRAME 2: evaluate total-weight-A (crystallized, deterministic)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { total-weight-A, weighted-sum-B, total-weight-B }
-- Picking total-weight-A (continue program A's path)

⊢ total-weight-A ▸ crystallized
  given input-data→weights ≡ [1, 2, 3, 4]
  yield total-weight

  ⊢= total-weight ← sum(weights)

-- deterministic evaluation:
--   sum = 1 + 2 + 3 + 4 = 10

  yield total-weight ≡ 10

-- oracle checks:
--   ⊨ total-weight = 1 + 2 + 3 + 4 = 10 → ✓ (10 = 10)

-- state after frame 2: total-weight-A frozen.
-- Ready set: { weighted-average-A, weighted-sum-B, total-weight-B }
-- weighted-average-A is now unblocked (both inputs frozen).

-- ═══════════════════════════════════════════════════════════════
-- FRAME 3: evaluate weighted-average-A (crystallized, deterministic)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { weighted-average-A, weighted-sum-B, total-weight-B }
-- Picking weighted-average-A (complete program A first)

⊢ weighted-average-A ▸ crystallized
  given weighted-sum-A→weighted-sum ≡ 300
  given total-weight-A→total-weight ≡ 10
  yield average

  ⊢= average ← weighted-sum / total-weight

-- deterministic evaluation:
--   average = 300 / 10 = 30

  yield average ≡ 30

-- oracle checks:
--   ⊨ average = 300 / 10 = 30 → ✓ (30 = 30)

-- state after frame 3: weighted-average-A frozen. Program A complete.
-- Ready set: { weighted-sum-B, total-weight-B }
-- Program B's independent cells are ready.

-- ═══════════════════════════════════════════════════════════════
-- FRAME 4: evaluate total-weight-B (crystallized, deterministic)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { weighted-sum-B, total-weight-B }
-- Picking total-weight-B (program B: count-first ordering)
-- NOTE: This is the key difference — B evaluates total-weight BEFORE
-- weighted-sum, opposite of A. Confluence says result is the same.

⊢ total-weight-B ▸ crystallized
  given input-data→weights ≡ [1, 2, 3, 4]
  yield total-weight

  ⊢= total-weight ← sum(weights)

-- deterministic evaluation:
--   sum = 1 + 2 + 3 + 4 = 10

  yield total-weight ≡ 10

-- oracle checks:
--   ⊨ total-weight = 1 + 2 + 3 + 4 = 10 → ✓ (10 = 10)

-- state after frame 4: total-weight-B frozen.
-- Ready set: { weighted-sum-B }
-- Note: weighted-average-B needs both sum and weight — still blocked on sum.

-- ═══════════════════════════════════════════════════════════════
-- FRAME 5: evaluate weighted-sum-B (crystallized, deterministic)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { weighted-sum-B }

⊢ weighted-sum-B ▸ crystallized
  given input-data→values ≡ [10, 20, 30, 40]
  given input-data→weights ≡ [1, 2, 3, 4]
  yield weighted-sum

  ⊢= weighted-sum ← sum(values[i] * weights[i] for i in 0..length(values))

-- deterministic evaluation:
--   values[0] * weights[0] = 10 * 1  = 10
--   values[1] * weights[1] = 20 * 2  = 40
--   values[2] * weights[2] = 30 * 3  = 90
--   values[3] * weights[3] = 40 * 4  = 160
--   sum = 10 + 40 + 90 + 160 = 300

  yield weighted-sum ≡ 300

-- oracle checks:
--   ⊨ weighted-sum = 10*1 + 20*2 + 30*3 + 40*4 = 300 → ✓ (300 = 300)

-- state after frame 5: weighted-sum-B frozen.
-- Ready set: { weighted-average-B }
-- Both inputs to weighted-average-B are now frozen.

-- ═══════════════════════════════════════════════════════════════
-- FRAME 6: evaluate weighted-average-B (crystallized, deterministic)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { weighted-average-B }

⊢ weighted-average-B ▸ crystallized
  given weighted-sum-B→weighted-sum ≡ 300
  given total-weight-B→total-weight ≡ 10
  yield average

  ⊢= average ← weighted-sum / total-weight

-- deterministic evaluation:
--   average = 300 / 10 = 30

  yield average ≡ 30

-- oracle checks:
--   ⊨ average = 300 / 10 = 30 → ✓ (30 = 30)

-- state after frame 6: weighted-average-B frozen. Program B complete.
-- Ready set: { program-A, program-B }
-- Both §-referencing assembly cells can now evaluate.

-- ═══════════════════════════════════════════════════════════════
-- FRAME 7: evaluate program-A (soft cell, LLM)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { program-A, program-B }
-- Picking program-A first.

⊢ program-A
  given §weighted-sum-A ≡ §(crystallized cell, ⊢= sum(values[i]*weights[i]...), yield weighted-sum ≡ 300)
  given §total-weight-A ≡ §(crystallized cell, ⊢= sum(weights), yield total-weight ≡ 10)
  given §weighted-average-A ≡ §(crystallized cell, ⊢= weighted-sum/total-weight, yield average ≡ 30)
  yield §program-A-cells[], execution-order-A

  ∴ Assemble program A with sum-first ordering...

-- LLM evaluation (simulated):

  yield §program-A-cells ≡ [§weighted-sum-A, §total-weight-A, §weighted-average-A]
  yield execution-order-A ≡ ["input-data", "weighted-sum-A", "total-weight-A", "weighted-average-A"]

-- oracle checks:
--   ⊨ execution-order-A is a valid topological sort → ✓
--     (input-data has no deps, weighted-sum-A needs input-data ✓,
--      total-weight-A needs input-data ✓, weighted-average-A needs both prior ✓)
--   ⊨ weighted-sum-A appears before total-weight-A → ✓ (index 1 < index 2)

-- state after frame 7: program-A frozen.
-- Ready set: { program-B }

-- ═══════════════════════════════════════════════════════════════
-- FRAME 8: evaluate program-B (soft cell, LLM)
-- ═══════════════════════════════════════════════════════════════
-- Ready set: { program-B }

⊢ program-B
  given §total-weight-B ≡ §(crystallized cell, ⊢= sum(weights), yield total-weight ≡ 10)
  given §weighted-sum-B ≡ §(crystallized cell, ⊢= sum(values[i]*weights[i]...), yield weighted-sum ≡ 300)
  given §weighted-average-B ≡ §(crystallized cell, ⊢= weighted-sum/total-weight, yield average ≡ 30)
  yield §program-B-cells[], execution-order-B

  ∴ Assemble program B with count-first ordering...

-- LLM evaluation (simulated):

  yield §program-B-cells ≡ [§total-weight-B, §weighted-sum-B, §weighted-average-B]
  yield execution-order-B ≡ ["input-data", "total-weight-B", "weighted-sum-B", "weighted-average-B"]

-- oracle checks:
--   ⊨ execution-order-B is a valid topological sort → ✓
--     (input-data has no deps, total-weight-B needs input-data ✓,
--      weighted-sum-B needs input-data ✓, weighted-average-B needs both prior ✓)
--   ⊨ total-weight-B appears before weighted-sum-B → ✓ (index 1 < index 2)

-- state after frame 8: program-B frozen.
-- Ready set: { trace-A, trace-B }
-- Both trace cells can now execute — they depend on program-A/B and input-data.
-- Confluence: trace-A and trace-B are independent, can run in either order.

