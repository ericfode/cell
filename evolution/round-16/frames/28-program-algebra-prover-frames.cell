-- ═══════════════════════════════════════════════════════════════
-- Ready set: { trace-B }

⊢ trace-B
  given program-B→execution-order-B ≡ ["input-data", "total-weight-B", "weighted-sum-B", "weighted-average-B"]
  given input-data→values ≡ [10, 20, 30, 40]
  given input-data→weights ≡ [1, 2, 3, 4]
  yield frames-B[], final-state-B

  ∴ Execute program B step by step...

-- LLM evaluation (simulated):

  yield frames-B ≡ [
    { step: 0, cell: "input-data",        inputs: { values: [10,20,30,40], weights: [1,2,3,4] },
      yields: { values: [10,20,30,40], weights: [1,2,3,4] }, oracles: ["✓","✓","✓"] },
    { step: 1, cell: "total-weight-B",    inputs: { weights: [1,2,3,4] },
      yields: { total-weight: 10 },        oracles: ["✓"] },
    { step: 2, cell: "weighted-sum-B",    inputs: { values: [10,20,30,40], weights: [1,2,3,4] },
      yields: { weighted-sum: 300 },       oracles: ["✓"] },
    { step: 3, cell: "weighted-average-B", inputs: { weighted-sum: 300, total-weight: 10 },
