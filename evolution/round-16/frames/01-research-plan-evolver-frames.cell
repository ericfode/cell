    { hypothesis: "H1 (charismatic maintainer)", evidence: "UNTESTED — experiment deemed infeasible. No data collected.", verdict: "unknown" },
    { hypothesis: "H2 (dependency flywheel)", evidence: "E2 SUPPORTS: 4.2x contributor growth for adopted packages. Flywheel is real but reversible — 13% died when framework switched away.", verdict: "supported with caveat" },
    { hypothesis: "H3 (onboarding friction)", evidence: "E3 INCONCLUSIVE: onboarding signals help (1.8-2.7x return rate) but explain only 22% of variance. Retention alone doesn't predict survival (0.41 AUC).", verdict: "partially supported, overstated" },
