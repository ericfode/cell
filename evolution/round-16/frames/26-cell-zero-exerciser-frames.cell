-- LLM evaluation (cell-zero.read-graph is a soft cell):
-- Scanning В§p1-parallel-confluence for вҠў declarations...
-- Found 5 cells. Scanning given XвҶ’Y references for edges...
-- Found 6 edges.

  yield cells вүЎ [
    { name: "config", givens: [topic вүЎ "the moon"], yields: [topic], body-type: "вҠЁ-only", oracles: ["topic is a noun phrase"] },
    { name: "poet", givens: [configвҶ’topic], yields: [poem], body-type: "вҲҙ", oracles: ["poem is exactly 3 lines", "poem follows 5-7-5 syllable pattern"] },
    { name: "scientist", givens: [configвҶ’topic], yields: [fact], body-type: "вҲҙ", oracles: ["fact is one sentence", "fact is factually accurate"] },
    { name: "child", givens: [configвҶ’topic], yields: [question], body-type: "вҲҙ", oracles: ["question ends with a question mark", "question uses simple vocabulary"] },
    { name: "combine", givens: [poetвҶ’poem, scientistвҶ’fact, childвҶ’question], yields: [document], body-type: "вҠў=", oracles: ["document contains all three inputs"] }
  ]

  yield edges вүЎ [
    { from: "config", from-output: "topic", to: "poet" },
    { from: "config", from-output: "topic", to: "scientist" },
    { from: "config", from-output: "topic", to: "child" },
    { from: "poet", from-output: "poem", to: "combine" },
    { from: "scientist", from-output: "fact", to: "combine" },
    { from: "child", from-output: "question", to: "combine" }
  ]

