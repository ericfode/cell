-- LLM evaluation:

  yield evidence-map ≡ [
    { hypothesis: "H1 (social presence)", evidence: "UNTESTED — experiment E1 deemed infeasible due to social media API restrictions. No data collected.", verdict: "unknown" },
    { hypothesis: "H2 (dependency flywheel)", evidence: "E2 SUPPORTS: 3.8x contributor growth for adopted packages vs controls. Flywheel effect peaks at 6 months post-adoption. But 14% of adopted packages still died — framework-native replacements, security incidents, or forks.", verdict: "supported with caveat" },
    { hypothesis: "H3 (onboarding friction)", evidence: "E3 INCONCLUSIVE: onboarding signals improve contributor return rate (1.9-3.1x) and explain 24% of variance. But contributor retention alone predicts survival at only 0.43 AUC. Retention is necessary but not sufficient for survival.", verdict: "partially supported, insufficient as sole predictor" },
    { hypothesis: "H4 (corporate backing)", evidence: "E4 SUPPORTS: 79% vs 28% survival after maintainer departure. Natural experiment subset (post-departure funding) shows 64% survival, confirming partial causal effect. ≥2 paid contributors is the key threshold (92% survival).", verdict: "supported with causal nuance" },
    { hypothesis: "H5 (niche uniqueness)", evidence: "E5 REFUTES: niche-uniqueness effect disappears when controlling for dependency PageRank. Uniqueness is a proxy for ecosystem position, not an independent survival factor. Top-uniqueness + low-PageRank: only 41% survival.", verdict: "refuted — mediated by dependency centrality" }
  ]

-- oracle checks:
