-- SPAWNED CELL: example-0
⊢ example-0
  yield code, label

  ⊢= label ← "simple"
  ⊢= code ← "RECIPE Scrambled Eggs with Toast SERVES 2 TIME 15 min

    INGREDIENTS:
      eggs 4 whole
      butter 1 tbsp OR olive-oil 1 tbsp RATIO 1:1
      bread 2 whole
      salt 1/4 tsp
      pepper 1/4 tsp

    STEPS:
      toast: toast bread FOR 3 min
      heat: melt butter in pan FOR 2 min THEN toast
      scramble: stir eggs gently in pan FOR 4 min THEN heat
      season: add salt and pepper FOR 1 min THEN scramble
  "

-- SPAWNED CELL: example-1
⊢ example-1
  yield code, label

  ⊢= label ← "medium"
  ⊢= code ← "RECIPE Pasta with Tomato Sauce SERVES 4 TIME 35 min

    INGREDIENTS:
      pasta 400 g
      fresh-tomatoes 6 whole OR canned-tomatoes 800 g RATIO 6:800
      garlic 3 cloves
      olive-oil 2 tbsp
      parmesan 50 g OR nutritional-yeast 30 g RATIO 5:3
      basil 10 g
      salt 1 tsp

    STEPS:
      boil-water: bring water to boil FOR 10 min
      cook-pasta: add pasta to boiling water FOR 12 min THEN boil-water
      saute: heat olive-oil and garlic FOR 3 min
      simmer-sauce: add tomatoes and simmer FOR 20 min THEN saute WHILE cook-pasta
      drain: drain pasta FOR 1 min THEN cook-pasta
      combine: toss pasta with sauce FOR 2 min THEN drain
      garnish: add parmesan and basil FOR 1 min THEN combine
  "

-- SPAWNED CELL: example-2
⊢ example-2
  yield code, label

  ⊢= label ← "complex"
  ⊢= code ← "RECIPE Stir-Fry with Rice SERVES 4 TIME 40 min

    INGREDIENTS:
      rice 2 cups
      chicken 500 g OR tofu 400 g RATIO 5:4
      broccoli 200 g
      bell-pepper 2 whole
      soy-sauce 3 tbsp
      ginger 1 tbsp
      garlic 2 cloves
      sesame-oil 1 tbsp
      vegetable-oil 2 tbsp

    STEPS:
      rice: cook rice in rice cooker FOR 30 min
      IF-SUB tofu: press tofu between towels FOR 15 min
      prep-veg: chop broccoli and bell pepper FOR 8 min WHILE rice
      heat-wok: heat wok with vegetable-oil FOR 2 min WAIT-UNTIL rice REMAINING 5 min
      cook-protein: stir-fry chicken or tofu FOR 5 min THEN heat-wok
      stir-fry-veg: add vegetables and stir-fry FOR 4 min THEN cook-protein
      sauce: add soy-sauce ginger garlic FOR 2 min THEN stir-fry-veg
      finish: drizzle sesame-oil and serve with rice FOR 1 min THEN sauce
  "

