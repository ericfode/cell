  yield pass-all вүЎ true
  yield results вүЎ [
    [1, 2, 0, 3],
    [0, 0, 0],
    [4, 3, 2, 1, 0],
    [0],
    [0, 3, 0, 2]
  ]
  yield failures вүЎ []

-- oracle checks:
