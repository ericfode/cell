    { step: 2, cell: "weighted-sum-B", inputs: { values: [10,20,30,40], weights: [1,2,3,4] }, yields: { weighted-sum: 300 }, oracles: ["300=300 вң“"] },
    { step: 3, cell: "weighted-average-B", inputs: { weighted-sum: 300, total-weight: 10 }, yields: { average: 30 }, oracles: ["30=30 вң“"] }
  ]
