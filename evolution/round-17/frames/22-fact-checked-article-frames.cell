  ⊢= fail-count ← count(fact-check-*→verdict, v -> v = "fail")  -- 2
  ⊢= uncertain-count ← count(fact-check-*→verdict, v -> v = "uncertain")  -- 0
  ⊢= failed-claims ← filter(zip(...), entry -> entry[1] = "fail")
  ⊢= all-pass ← if 2 = 0 and 0 = 0 then true else false  -- false

  yield pass-count ≡ 14
  yield fail-count ≡ 2
  yield uncertain-count ≡ 0
  yield failed-claims ≡ [
    { claim: "CVS was created by Dick Grune in 1986.", correction: "CVS was created by Dick Grune in 1986 as a series of shell scripts wrapping RCS." },
