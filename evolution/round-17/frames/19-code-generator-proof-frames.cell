  given generate-proof-sketch→invariants ≡ ["If target exists in arr[0..n-1], then target is in arr[lo..hi] at the start of each iteration"]
  given generate-proof-sketch→termination-argument ≡ "The variant V = hi - lo + 1 is a natural number that strictly decreases by at least 1 on each iteration... bounded below by 0..."
