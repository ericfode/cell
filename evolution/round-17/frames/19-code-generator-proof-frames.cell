  yield results ≡ [
    { test: 1, input: "[1,3,5,7,9], 5", actual: 2, expected: 2, verdict: "pass" },
    { test: 2, input: "[2,4,6,8,10], 8", actual: 3, expected: 3, verdict: "pass" },
    { test: 3, input: "[1,3,5,7,9], 4", actual: -1, expected: -1, verdict: "pass" },
    { test: 4, input: "[1,3,5,7,9], 0", actual: -1, expected: -1, verdict: "pass" },
    { test: 5, input: "[10,20,30,40,50], 10", actual: 0, expected: 0, verdict: "pass" },
    { test: 6, input: "[10,20,30,40,50], 50", actual: 4, expected: 4, verdict: "pass" },
    { test: 7, input: "[1,2,3,4,5,6,7], 1", actual: 0, expected: 0, verdict: "pass" },
    { test: 8, input: "[42], 42", actual: 0, expected: 0, verdict: "pass" },
    { test: 9, input: "[42], 99", actual: -1, expected: -1, verdict: "pass" },
    { test: 10, input: "[], 5", actual: -1, expected: -1, verdict: "pass" },
    { test: 11, input: "[1,2,3,4,5,6,7], 4", actual: 3, expected: 3, verdict: "pass" },
    { test: 12, input: "[1,3,5,7,9,11,13], 7", actual: 3, expected: 3, verdict: "pass" }
  ]
  yield pass-count ≡ 12
  yield fail-count ≡ 0
  yield failure-details ≡ []

-- oracle checks:
