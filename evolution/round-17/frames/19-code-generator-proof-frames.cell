-- 19-code-generator-proof-frames.cell — full execution trace (R17, v0.2)
--
-- Ready set analysis (initial):
--   spec: given description/signature/preconditions all ≡-bound → READY
--   generate-code: given spec→* → BLOCKED (needs spec)
--   generate-property-tests: given spec→* → BLOCKED (needs spec)
--   run-tests: given generate-code→code-text, tests→test-cases → BLOCKED
--   analyze-failures: given run-tests→fail-count where >0 → BLOCKED
--   skip-analysis: given run-tests→fail-count where =0 → BLOCKED
--   rewrite-code: given analyze-failures→fix-strategy where !="none" → BLOCKED
--   skip-rewrite: given skip-analysis→fix-strategy where ="none" → BLOCKED
--   ⊢∘ evolve: coordinates iteration over {generate-code, run-tests, analyze-failures, rewrite-code}
--   generate-proof-sketch: given rewrite-code→code-text' → BLOCKED
--   verify-proof-structural: given generate-proof-sketch→* → BLOCKED
--   verify-proof-semantic: given generate-proof-sketch→* → BLOCKED
--   proof-certificate-high: given verify-proof-semantic→verdict where ="proof complete" → BLOCKED
--   proof-certificate-medium: given verify-proof-semantic→verdict where ="proof valid with minor gaps" → BLOCKED
--   proof-certificate-low: given verify-proof-semantic→verdict where ="proof incomplete" → BLOCKED
--
-- Ready set: { spec }
--
-- v0.2 execution notes:
--   - ⊨? at file scope applies as default recovery for all cells
--   - Oracles on generate-code are aspirational under ⊢∘ management
--   - Guard clauses on analyze-failures/skip-analysis dispatch on fail-count
--   - Guard clauses on rewrite-code/skip-rewrite dispatch on fix-strategy
--   - Guard clauses on proof-certificate-{high,medium,low} dispatch on verdict
--   - verify-proof split: structural (⊢=, crystallized) + semantic (∴, honest)
--   - R16's verify-proof ⊢= used undefined functions (proof-covers, missing-from,
--     has-loop-invariant) — semantic judgments. v0.2 moves these to ∴ cell.

-- ═══════════════════════════════════════════════════════════════
-- frame 0: spec (soft cell with ≡-bound inputs, trivial evaluation)
-- ═══════════════════════════════════════════════════════════════

⊢ spec
  given description ≡ "binary search on sorted array, returns index or -1"
  given signature ≡ "binary_search(arr: int[], target: int) -> int"
  given preconditions ≡ "arr is sorted in ascending order, no duplicates"
  yield description, signature, preconditions

  yield description ≡ "binary search on sorted array, returns index or -1"
  yield signature ≡ "binary_search(arr: int[], target: int) -> int"
  yield preconditions ≡ "arr is sorted in ascending order, no duplicates"

-- oracle checks:
--   ⊨ description specifies the algorithm, input, and output → ✓
--     ("binary search" = algorithm, "sorted array" = input, "index or -1" = output)
--   ⊨ signature has typed parameters and return type → ✓
--     (arr: int[], target: int → int)
--   ⊨ preconditions constrain the input space → ✓
--     ("sorted in ascending order, no duplicates")
--
-- All oracles pass. Cell frozen.

-- Ready set after: { generate-code, generate-property-tests }
-- (spec→description, spec→signature, spec→preconditions now bound)
-- Both cells have all given deps satisfied. They are independent — eval
-- either first. We pick generate-property-tests (order doesn't matter
-- by confluence, but tests before code lets us see what we're testing).

-- ═══════════════════════════════════════════════════════════════
-- frame 1: generate-property-tests (soft cell, LLM evaluation)
-- ═══════════════════════════════════════════════════════════════

⊢ generate-property-tests
  given spec→signature ≡ "binary_search(arr: int[], target: int) -> int"
  given spec→preconditions ≡ "arr is sorted in ascending order, no duplicates"
  given spec→description ≡ "binary search on sorted array, returns index or -1"
  yield test-cases[], properties[]

  ∴ Generate property-based test cases for «spec→signature».

    Properties to test:
    1. Found element: if target in arr, result is its index
    2. Not found: if target not in arr, result is -1
    3. Boundary: target at first position, last position
    4. Single element: array of size 1
    5. Empty array: result must be -1
    6. Midpoint correctness: target at exact midpoint

    For each property, generate 2-3 concrete test cases with
    { input-arr, input-target, expected-output }.

-- LLM evaluation:
-- The prompt is straightforward: enumerate properties and generate concrete
-- test cases. The LLM produces a structured list covering all 6 properties.

  yield test-cases ≡ [
    { input-arr: [1, 3, 5, 7, 9], input-target: 5, expected-output: 2 },
    { input-arr: [2, 4, 6, 8, 10], input-target: 8, expected-output: 3 },
    { input-arr: [1, 3, 5, 7, 9], input-target: 4, expected-output: -1 },
    { input-arr: [1, 3, 5, 7, 9], input-target: 0, expected-output: -1 },
    { input-arr: [10, 20, 30, 40, 50], input-target: 10, expected-output: 0 },
    { input-arr: [10, 20, 30, 40, 50], input-target: 50, expected-output: 4 },
    { input-arr: [1, 2, 3, 4, 5, 6, 7], input-target: 1, expected-output: 0 },
    { input-arr: [42], input-target: 42, expected-output: 0 },
    { input-arr: [42], input-target: 99, expected-output: -1 },
    { input-arr: [], input-target: 5, expected-output: -1 },
    { input-arr: [1, 2, 3, 4, 5, 6, 7], input-target: 4, expected-output: 3 },
    { input-arr: [1, 3, 5, 7, 9, 11, 13], input-target: 7, expected-output: 3 }
  ]
  yield properties ≡ [
    "found-element: if target in arr, binary_search returns its 0-based index",
    "not-found: if target not in arr, binary_search returns -1",
    "boundary-first: target at index 0 returns 0",
    "boundary-last: target at last index returns len(arr)-1",
    "single-element-found: array of size 1, target present, returns 0",
    "single-element-not-found: array of size 1, target absent, returns -1",
    "empty-array: array of size 0, returns -1",
    "midpoint: target at exact center of odd-length array"
  ]

-- oracle checks:
--   ⊨ len(test-cases) >= 10 → ✓ (12 test cases)
--   ⊨ properties covers found, not-found, boundary, and edge cases → ✓
--     (found-element, not-found, boundary-first, boundary-last, single-*,
--      empty-array, midpoint — all categories covered)
--   ⊨ each test-case has input-arr (sorted), input-target, expected-output → ✓
--     (all 12 have the required fields; all input-arr are sorted ascending)
--
-- All oracles pass. Cell frozen.

-- Ready set after: { generate-code }
-- (generate-property-tests frozen, but run-tests still needs generate-code→code-text)

-- ═══════════════════════════════════════════════════════════════
-- ⊢∘ ITERATION 0 — initial code generation
-- ═══════════════════════════════════════════════════════════════

-- ═══════════════════════════════════════════════════════════════
-- frame 2: generate-code v0 (soft cell, LLM evaluation)
-- ═══════════════════════════════════════════════════════════════

⊢ generate-code
  given spec→description ≡ "binary search on sorted array, returns index or -1"
  given spec→signature ≡ "binary_search(arr: int[], target: int) -> int"
  given spec→preconditions ≡ "arr is sorted in ascending order, no duplicates"
  yield §implementation, code-text

  ∴ Write a correct implementation of «spec→signature» that satisfies:
    «spec→description»
    Preconditions: «spec→preconditions»

    Use a standard binary search algorithm. Return the 0-based index of
    «target» in «arr», or -1 if not found. The implementation must:
    - Use integer midpoint calculation that avoids overflow
    - Maintain loop invariant: target is in arr[lo..hi] if present
    - Terminate when lo > hi (not found) or arr[mid] == target (found)

    Output the code as a Cell ⊢= expression.

-- LLM evaluation:
-- The LLM generates a binary search. We simulate a subtle bug: the initial
-- implementation uses `lo + (hi - lo) / 2` for midpoint (correct), but has
-- an off-by-one in the not-found termination: `while lo < hi` instead of
-- `while lo <= hi`. This causes single-element arrays and boundary cases
-- to fail — a realistic LLM coding mistake.

  yield §implementation ≡ "⊢= binary_search(arr, target) ←
    lo ← 0
    hi ← len(arr) - 1
    while lo < hi:
      mid ← lo + (hi - lo) / 2
      if arr[mid] = target then return mid
      else if arr[mid] < target then lo ← mid + 1
      else hi ← mid - 1
    return -1"

  yield code-text ≡ "lo ← 0; hi ← len(arr) - 1; while lo < hi: mid ← lo + (hi - lo) / 2; if arr[mid] = target then return mid; else if arr[mid] < target then lo ← mid + 1; else hi ← mid - 1; return -1"

-- v0.2: aspirational oracle checks (generate-code is ⊢∘-managed):
--   ⊨ code-text contains a loop or recursive structure → ✓ ("while lo < hi")
--   ⊨ code-text returns -1 for not-found case → ✓ ("return -1" at end)
--   ⊨ code-text uses integer division for midpoint → ✓ ("lo + (hi - lo) / 2")
--
-- Aspirational oracles all pass. But the code has a bug: `while lo < hi`
-- should be `while lo <= hi`. The bug will surface in run-tests.
-- Under v0.2 ⊢∘ semantics, these oracles don't independently block freezing.

-- Ready set after: { run-tests }
-- (generate-code→code-text and generate-property-tests→test-cases both bound)

-- ═══════════════════════════════════════════════════════════════
-- frame 3: run-tests v0 (soft cell, LLM simulates execution)
-- ═══════════════════════════════════════════════════════════════

⊢ run-tests
  given generate-code→code-text ≡ "lo ← 0; hi ← len(arr) - 1; while lo < hi: mid ← lo + (hi - lo) / 2; if arr[mid] = target then return mid; else if arr[mid] < target then lo ← mid + 1; else hi ← mid - 1; return -1"
  given generate-property-tests→test-cases ≡ "(12 test cases as above)"
  yield results[], pass-count, fail-count, failure-details[]

  ∴ Simulate executing «generate-code→code-text» on each test case
    in «generate-property-tests→test-cases». For each test:
    - Trace through the code with the given inputs
    - Record the actual output
    - Compare to expected-output
    - If mismatch: record the failure with step-by-step trace showing
      where the code diverged from expected behavior

-- LLM evaluation:
-- The LLM traces the code on all 12 test cases. The bug `while lo < hi`
-- (should be `while lo <= hi`) causes failures when lo = hi and the target
-- is at that position. Specifically:
--
-- Test 8: [42], target=42 → lo=0, hi=0, lo < hi is FALSE → returns -1
--   Expected: 0. FAIL.
-- Test 5: [10,20,30,40,50], target=10 → lo=0, hi=4, mid=2, arr[2]=30>10,
--   hi=1, mid=0, arr[0]=10 → return 0. PASS. (lucky: found before lo=hi)
-- Test 6: [10,20,30,40,50], target=50 → lo=0, hi=4, mid=2, arr[2]=30<50,
--   lo=3, mid=3, arr[3]=40<50, lo=4, lo < hi is FALSE → returns -1.
--   Expected: 4. FAIL.
-- Test 7: [1,2,3,4,5,6,7], target=1 → lo=0, hi=6, mid=3, arr[3]=4>1,
--   hi=2, mid=1, arr[1]=2>1, hi=0, lo < hi is FALSE → returns -1.
--   Expected: 0. FAIL.

  yield results ≡ [
    { test: 1, input: "[1,3,5,7,9], 5", actual: 2, expected: 2, verdict: "pass" },
    { test: 2, input: "[2,4,6,8,10], 8", actual: 3, expected: 3, verdict: "pass" },
    { test: 3, input: "[1,3,5,7,9], 4", actual: -1, expected: -1, verdict: "pass" },
    { test: 4, input: "[1,3,5,7,9], 0", actual: -1, expected: -1, verdict: "pass" },
    { test: 5, input: "[10,20,30,40,50], 10", actual: 0, expected: 0, verdict: "pass" },
    { test: 6, input: "[10,20,30,40,50], 50", actual: -1, expected: 4, verdict: "FAIL" },
    { test: 7, input: "[1,2,3,4,5,6,7], 1", actual: -1, expected: 0, verdict: "FAIL" },
    { test: 8, input: "[42], 42", actual: -1, expected: 0, verdict: "FAIL" },
    { test: 9, input: "[42], 99", actual: -1, expected: -1, verdict: "pass" },
    { test: 10, input: "[], 5", actual: -1, expected: -1, verdict: "pass" },
    { test: 11, input: "[1,2,3,4,5,6,7], 4", actual: 3, expected: 3, verdict: "pass" },
    { test: 12, input: "[1,3,5,7,9,11,13], 7", actual: 3, expected: 3, verdict: "pass" }
  ]
  yield pass-count ≡ 9
  yield fail-count ≡ 3
  yield failure-details ≡ [
    { test: 6, trace: "arr=[10,20,30,40,50], target=50: lo=0 hi=4 → mid=2 arr[2]=30<50 lo=3 → mid=3 arr[3]=40<50 lo=4 → lo(4) < hi(4) is FALSE → return -1. Bug: loop exits when lo=hi=4, never checks arr[4]=50.", expected: 4, actual: -1 },
    { test: 7, trace: "arr=[1,2,3,4,5,6,7], target=1: lo=0 hi=6 → mid=3 arr[3]=4>1 hi=2 → mid=1 arr[1]=2>1 hi=0 → lo(0) < hi(0) is FALSE → return -1. Bug: loop exits when lo=hi=0, never checks arr[0]=1.", expected: 0, actual: -1 },
    { test: 8, trace: "arr=[42], target=42: lo=0 hi=0 → lo(0) < hi(0) is FALSE → return -1. Bug: single element, loop body never entered.", expected: 0, actual: -1 }
  ]

-- oracle checks:
--   ⊨ len(results) = len(test-cases) → ✓ (12 = 12)
--   ⊨ pass-count + fail-count = len(results) → ✓ (9 + 3 = 12)
--   ⊨ if fail-count > 0 then len(failure-details) = fail-count → ✓ (3 > 0, 3 = 3)
--
-- All oracles pass. Cell frozen.

-- Ready set after: { analyze-failures, skip-analysis }
-- Guard evaluation:
--   analyze-failures: given run-tests→fail-count where fail-count > 0 → 3 > 0 → TRUE → READY
--   skip-analysis: given run-tests→fail-count where fail-count = 0 → 3 = 0 → FALSE → SKIPPED
--
-- skip-analysis is SKIPPED. Its yields become ⊥.
-- Ready set: { analyze-failures }

-- ═══════════════════════════════════════════════════════════════
-- frame 4: analyze-failures (soft cell, LLM evaluation)
--   guard: run-tests→fail-count(3) > 0 → TRUE
--   skip-analysis: SKIPPED (guard false), all yields ≡ ⊥
-- ═══════════════════════════════════════════════════════════════

⊢ analyze-failures
  given run-tests→fail-count ≡ 3
  given run-tests→failure-details ≡ "(3 failure traces as above)"
  given generate-code→code-text ≡ "(binary search with while lo < hi)"
  yield diagnosis, bug-category, fix-strategy

  ∴ Analyze «run-tests→failure-details» against
    «generate-code→code-text». For each failure:
    - Identify the root cause (off-by-one, wrong comparison, overflow, etc.)
    - Categorize the bug
    - Propose a specific fix (which line, what change)

-- LLM evaluation:
-- All three failures share the same root cause: the loop condition `while lo < hi`
-- exits before checking the case where lo = hi. The fix is `while lo <= hi`.

  yield diagnosis ≡ "All 3 failures share one root cause: the loop condition 'while lo < hi' terminates the loop when lo = hi without checking arr[lo]. When the target is at the position where lo converges to hi (last element, first element via hi-reduction, single-element array), it is never compared. The loop should continue while lo <= hi to check the final remaining position."
  yield bug-category ≡ "off-by-one"
  yield fix-strategy ≡ "Change 'while lo < hi' to 'while lo <= hi'. This is a single-character fix (< to <=) on the loop condition line. No other lines need to change. The midpoint calculation, comparisons, and return logic are all correct."

-- oracle checks:
--   ⊨ fix-strategy describes a concrete code change → ✓
--     ("Change 'while lo < hi' to 'while lo <= hi'" — names the exact change)
--   ⊨ bug-category ∈ {"off-by-one", ...} → ✓ ("off-by-one")
--
-- All oracles pass. Cell frozen.

-- Ready set after: { rewrite-code, skip-rewrite }
-- Guard evaluation:
--   rewrite-code: given analyze-failures→fix-strategy where !="none"
--     → "Change while..." != "none" → TRUE → READY
--   skip-rewrite: given skip-analysis→fix-strategy where ="none"
--     → skip-analysis yields are all ⊥ (cell was skipped) → BLOCKED permanently
--
-- Ready set: { rewrite-code }

-- ═══════════════════════════════════════════════════════════════
-- frame 5: rewrite-code v0 (soft cell, LLM evaluation)
--   guard: analyze-failures→fix-strategy("Change...") != "none" → TRUE
--   skip-rewrite: BLOCKED (depends on skip-analysis which yielded ⊥)
-- ═══════════════════════════════════════════════════════════════

⊢ rewrite-code
  given analyze-failures→fix-strategy ≡ "Change 'while lo < hi' to 'while lo <= hi'. Single-character fix on the loop condition line."
  given analyze-failures→diagnosis ≡ "Loop condition 'while lo < hi' terminates when lo = hi without checking arr[lo]..."
  given generate-code→code-text ≡ "lo ← 0; hi ← len(arr) - 1; while lo < hi: mid ← lo + (hi - lo) / 2; if arr[mid] = target then return mid; else if arr[mid] < target then lo ← mid + 1; else hi ← mid - 1; return -1"
  given run-tests→failure-details ≡ "(3 failure traces)"
  yield §implementation', code-text', changed-lines[]

  ∴ Apply «analyze-failures→fix-strategy» to
    «generate-code→code-text». Rewrite only the lines that need fixing.
    Record which lines changed and why.

    The rewritten code must preserve the function signature and
    overall structure. Only fix what's broken.

-- LLM evaluation:
-- The fix is surgical: change `while lo < hi` to `while lo <= hi`.
-- Everything else stays the same.

  yield §implementation' ≡ "⊢= binary_search(arr, target) ←
    lo ← 0
    hi ← len(arr) - 1
    while lo <= hi:
      mid ← lo + (hi - lo) / 2
      if arr[mid] = target then return mid
      else if arr[mid] < target then lo ← mid + 1
      else hi ← mid - 1
    return -1"

  yield code-text' ≡ "lo ← 0; hi ← len(arr) - 1; while lo <= hi: mid ← lo + (hi - lo) / 2; if arr[mid] = target then return mid; else if arr[mid] < target then lo ← mid + 1; else hi ← mid - 1; return -1"

  yield changed-lines ≡ [
    { line: 3, old: "while lo < hi:", new: "while lo <= hi:", reason: "Off-by-one: loop must check the final position where lo = hi" }
  ]

-- oracle checks:
--   ⊨ §implementation' has same given/yield signature as §generate-code → ✓
--     (both take arr, target, return int; same interface)
--   ⊨ len(changed-lines) >= 1 → ✓ (1 line changed)
--
-- All oracles pass. Cell frozen.

-- ⊢∘ applies the rewrite: generate-code is replaced by the fixed version.
-- ⊢∘ checks: run-tests→fail-count = 0? No, it was 3. Re-run with new code.

