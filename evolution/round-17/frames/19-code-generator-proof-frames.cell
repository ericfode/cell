  given generate-property-tests→test-cases ≡ "(12 test cases)"
  yield results[], pass-count, fail-count, failure-details[]

  ∴ Simulate executing «generate-code→code-text» on each test case...

-- LLM evaluation:
-- With `while lo <= hi`, all previously failing tests now pass:
-- Test 6: [10,20,30,40,50], target=50 → lo=4 hi=4 → lo<=hi TRUE → mid=4
--   arr[4]=50=target → return 4. ✓
-- Test 7: [1,2,3,4,5,6,7], target=1 → lo=0 hi=0 → lo<=hi TRUE → mid=0
--   arr[0]=1=target → return 0. ✓
-- Test 8: [42], target=42 → lo=0 hi=0 → lo<=hi TRUE → mid=0
