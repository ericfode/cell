  -- true or ... → true

  ⊢= step-count ← len(split(proof-sketch, "Proposition"))
  -- split on "Proposition" produces: ["", " 1 ...", " 2 ...", " 3 ...", " 4 ...", " 5 ..."]
  -- len = 6 (one empty + five propositions)

  yield has-invariant ≡ true
  yield has-termination ≡ true
  yield invariant-refs-vars ≡ true
  yield step-count ≡ 6

