⊢ generate-code
  given spec→description ≡ "binary search on sorted array, returns index or -1"
  given spec→signature ≡ "binary_search(arr: int[], target: int) -> int"
  given spec→preconditions ≡ "arr is sorted in ascending order, no duplicates"
  yield §implementation, code-text

  -- ⊢∘ replaced the ∴ body. The implementation is now the rewritten version.

  yield code-text ≡ "lo ← 0; hi ← len(arr) - 1; while lo <= hi: mid ← lo + (hi - lo) / 2; if arr[mid] = target then return mid; else if arr[mid] < target then lo ← mid + 1; else hi ← mid - 1; return -1"

-- v0.2: aspirational oracle checks:
--   ⊨ code-text contains a loop or recursive structure → ✓ ("while lo <= hi")
