-- LLM evaluation:
-- "Private" decomposes into access control, transport security, storage
-- security. End-to-end encryption is aspirational for a first version.

  yield sub-requirements вүЎ [
    "Only participants in a conversation can read messages in that conversation (access control)",
    "Messages are encrypted in transit using TLS 1.2 or higher",
    "Messages are encrypted at rest in the database using AES-256 or equivalent",
    "Server administrators cannot read message plaintext without explicit user consent"
  ]
  yield all-concrete вүЎ false

-- oracle checks:
