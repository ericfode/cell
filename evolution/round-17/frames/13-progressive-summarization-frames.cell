--   summarize:             frozen (level 1: 155 words, ~45% of original)
--   check-fidelity:        frozen (fidelity 7/10, acceptable = true)
--   compress-further:      frozen (level 2: 82 words, ~24% of original)
--   summarize-1:           frozen (level 2 re-summary: 88 words, after 3 retries)
--   check-fidelity-1:      frozen (fidelity 3/10, acceptable = false)
--   compress-further-1:    SKIPPED (guard-induced вҠҘ, all yields вүЎ вҠҘ)
