-- LLM evaluation:

  yield patched-code ≡ "import hashlib
import secrets

def login(username, password):
    if username not in users:
        return None
    stored_hash, salt = users[username]
    password_hash = hashlib.pbkdf2_hmac('sha256', password.encode(), salt, 100000)
    if secrets.compare_digest(stored_hash, password_hash):
        return create_session(username)
    return None"

  yield patch-description ≡ "Replaced plaintext password comparison with PBKDF2-HMAC-SHA256 hashed comparison. The users dictionary now stores (hash, salt) tuples instead of plaintext passwords. Uses secrets.compare_digest for constant-time comparison to prevent timing attacks. The membership check from the previous patch is preserved. The salt and 100,000 iterations make rainbow table attacks infeasible."

-- oracle checks (ASPIRATIONAL):
--   ⊨ patched-code is valid Python → ✓
--   ⊨ patched-code fixes the identified vulnerability → ✓ (hashed passwords)
--   ⊨ patch-description explains what changed and why → ✓
