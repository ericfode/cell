-- LLM evaluation:

  yield patched-code ≡ "import hashlib
import secrets
import time

_failed_attempts = {}
MAX_ATTEMPTS = 5
LOCKOUT_SECONDS = 300

def login(username, password):
    if username not in users:
        return None
    lockout_until = _failed_attempts.get(username, {}).get('until', 0)
    if time.time() < lockout_until:
        return None
    stored_hash, salt = users[username]
    password_hash = hashlib.pbkdf2_hmac('sha256', password.encode(), salt, 100000)
    if secrets.compare_digest(stored_hash, password_hash):
        _failed_attempts.pop(username, None)
        return create_session(username)
    record = _failed_attempts.setdefault(username, {'count': 0, 'until': 0})
    record['count'] += 1
    if record['count'] >= MAX_ATTEMPTS:
        record['until'] = time.time() + LOCKOUT_SECONDS
        record['count'] = 0
    return None"

  yield patch-description ≡ "Added account lockout mechanism: after 5 consecutive failed attempts, the account is locked for 300 seconds (5 minutes). Uses a module-level dictionary to track failed attempts per username. Successful login resets the counter. Locked accounts return None indistinguishably from wrong-password, preventing information leakage about lockout status. Previous patches preserved: membership check and hashed comparison intact."

-- oracle checks (ASPIRATIONAL):
--   ⊨ patched-code is valid Python → ✓
--   ⊨ patched-code fixes the vulnerability → ✓ (rate limiting via lockout)
--   ⊨ patch-description explains changes → ✓
--   ⊨ patched-code preserves correct login → ✓ (valid credentials work when not locked out)

