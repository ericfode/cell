import secrets
import time

_failed_attempts = {}
MAX_ATTEMPTS = 5
LOCKOUT_SECONDS = 300
_DUMMY_SALT = secrets.token_bytes(16)
_DUMMY_HASH = hashlib.pbkdf2_hmac('sha256', b'dummy', _DUMMY_SALT, 100000)

def login(username, password):
    if username not in users:
        hashlib.pbkdf2_hmac('sha256', password.encode(), _DUMMY_SALT, 100000)
        return None
    lockout_until = _failed_attempts.get(username, {}).get('until', 0)
    if time.time() < lockout_until:
        return None
    stored_hash, salt = users[username]
    password_hash = hashlib.pbkdf2_hmac('sha256', password.encode(), salt, 100000)
    if secrets.compare_digest(stored_hash, password_hash):
        _failed_attempts.pop(username, None)
        return create_session(username)
    record = _failed_attempts.setdefault(username, {'count': 0, 'until': 0})
    record['count'] += 1
    if record['count'] >= MAX_ATTEMPTS:
        record['until'] = time.time() + LOCKOUT_SECONDS
        record['count'] = 0
    return None"

  yield vulnerabilities-found ≡ [
    "Round 1 (CRITICAL, auth-bypass): KeyError on nonexistent username — dictionary access crashes without membership check, enabling username enumeration and DoS.",
    "Round 2 (CRITICAL, info-leak): Plaintext password comparison — passwords stored and compared in cleartext, trivially extractable via any data exposure.",
    "Round 3 (HIGH, auth-bypass): No rate limiting or account lockout — unlimited brute-force attempts with no delay or penalty.",
    "Round 4 (MEDIUM, info-leak): Timing side-channel on username existence — nonexistent-user path returned instantly while wrong-password path took ~100ms for PBKDF2."
