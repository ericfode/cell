-- 04-self-building-test-suite-frames.cell — full eval-one execution trace
--
-- Ready set analysis:
--   function-spec: all givens have ≡ (signature, behavior) → READY
--   generate-initial-tests: needs function-spec→signature, function-spec→behavior → BLOCKED
--   run-tests: needs generate-initial-tests→test-cases, function-spec→{signature,behavior} → BLOCKED
--   discover-edge-cases: needs run-tests→results, function-spec→behavior,
--     generate-initial-tests→categories; given? refine-test-suite→refined-edge-cases (⊥ OK) → BLOCKED
--   spawn-edge-tests: needs discover-edge-cases→edge-cases, function-spec→{signature,behavior}, §edge-test-template → BLOCKED
--   edge-test-template: template (not instantiated yet) → N/A
--   assess-coverage: needs run-tests→results, edge-test-*→{result,verdict}; given? edge-test-*→deeper-edges → BLOCKED
--   refine-test-suite: needs assess-coverage→gaps; given? assess-coverage→ambiguities → BLOCKED
--   final-report: needs assess-coverage→coverage-score (where >= 8), edge-test-*→{result,verdict} → BLOCKED
--   needs-more-work: needs assess-coverage→coverage-score (where < 8), assess-coverage→gaps → BLOCKED
--
-- Ready set: { function-spec }
-- Pre-loop chain: function-spec → generate-initial-tests → run-tests
-- ⊢∘ evolve loop: discover-edge-cases → [spawn-edge-tests → edge-test-*] → assess-coverage → refine-test-suite (max 3 iters)
-- Post-loop: final-report XOR needs-more-work (guard-gated on coverage-score)
--
-- File-scope ⊨? applies to all cells without their own ⊨?:
--   on failure: retry with «oracle.failures» max 3
--   on exhaustion: partial-accept(best)

-- ═══════════════════════════════════════════════════════════════
-- frame 0: function-spec
-- ═══════════════════════════════════════════════════════════════

-- function-spec is a data cell — all yields determined by givens. Freezes immediately.

⊢ function-spec
  given signature ≡ "parse_date(s: string) -> Date"
  given behavior ≡ "Parses dates in any common format. Accepts ISO 8601 (2024-03-15, 2024-03-15T10:30:00Z), US format (03/15/2024, March 15 2024), European format (15.03.2024, 15/03/2024), and natural language (next Tuesday, yesterday, in 3 days). Returns a Date with year, month, day fields. Raises ValueError on unparseable input."
  yield signature ≡ "parse_date(s: string) -> Date"
  yield behavior ≡ "Parses dates in any common format. Accepts ISO 8601 (2024-03-15, 2024-03-15T10:30:00Z), US format (03/15/2024, March 15 2024), European format (15.03.2024, 15/03/2024), and natural language (next Tuesday, yesterday, in 3 days). Returns a Date with year, month, day fields. Raises ValueError on unparseable input."

  ⊨ signature specifies input and output types → ✓ (s: string → Date)
  ⊨ behavior describes at least 3 distinct input formats → ✓ (ISO, US, European, natural language = 4)

-- Ready set after frame 0: { generate-initial-tests }

-- ═══════════════════════════════════════════════════════════════
-- frame 1: generate-initial-tests
-- ═══════════════════════════════════════════════════════════════

-- Soft cell. LLM generates initial happy-path test cases.

⊢ generate-initial-tests
  given function-spec→signature ≡ "parse_date(s: string) -> Date"
  given function-spec→behavior ≡ "Parses dates in any common format. Accepts ISO 8601 (2024-03-15, 2024-03-15T10:30:00Z), US format (03/15/2024, March 15 2024), European format (15.03.2024, 15/03/2024), and natural language (next Tuesday, yesterday, in 3 days). Returns a Date with year, month, day fields. Raises ValueError on unparseable input."
  yield test-cases[], categories[]

  ∴ Given the function «function-spec→signature» with behavior: ...
    Generate 5-7 initial test cases covering the obvious happy paths.

-- LLM evaluation:
-- One test per format family plus one error case. These are the OBVIOUS inputs.
-- Edge cases will come later from discover-edge-cases.

  yield test-cases ≡ [
    { input: "2024-03-15", expected-output: { year: 2024, month: 3, day: 15 }, category: "iso" },
    { input: "2024-03-15T10:30:00Z", expected-output: { year: 2024, month: 3, day: 15 }, category: "iso" },
    { input: "03/15/2024", expected-output: { year: 2024, month: 3, day: 15 }, category: "us" },
    { input: "March 15 2024", expected-output: { year: 2024, month: 3, day: 15 }, category: "us" },
    { input: "15.03.2024", expected-output: { year: 2024, month: 3, day: 15 }, category: "european" },
    { input: "yesterday", expected-output: { year: 2026, month: 3, day: 10 }, category: "natural-language" },
    { input: "not-a-date-at-all", expected-output: "ValueError", category: "error" }
  ]

  yield categories ≡ ["iso", "us", "european", "natural-language", "error"]

-- oracle checks:
--   ⊨ len(test-cases) >= 5 → ✓ (7 test cases)
--   ⊨ categories covers at least 3 distinct format families → ✓ (5 categories)
--   ⊨ each test-case has input, expected-output, and category fields → ✓

-- Ready set after frame 1: { run-tests }

-- ═══════════════════════════════════════════════════════════════
-- frame 2: run-tests
-- ═══════════════════════════════════════════════════════════════

-- Soft cell. LLM simulates execution of parse_date on each test case.

⊢ run-tests
  given generate-initial-tests→test-cases ≡ [
    { input: "2024-03-15", expected-output: { year: 2024, month: 3, day: 15 }, category: "iso" },
    { input: "2024-03-15T10:30:00Z", expected-output: { year: 2024, month: 3, day: 15 }, category: "iso" },
    { input: "03/15/2024", expected-output: { year: 2024, month: 3, day: 15 }, category: "us" },
    { input: "March 15 2024", expected-output: { year: 2024, month: 3, day: 15 }, category: "us" },
    { input: "15.03.2024", expected-output: { year: 2024, month: 3, day: 15 }, category: "european" },
    { input: "yesterday", expected-output: { year: 2026, month: 3, day: 10 }, category: "natural-language" },
    { input: "not-a-date-at-all", expected-output: "ValueError", category: "error" }
  ]
  given function-spec→signature ≡ "parse_date(s: string) -> Date"
  given function-spec→behavior ≡ "Parses dates in any common format..."
  yield results[], pass-count, fail-count

  ∴ Simulate executing «function-spec→signature» on each test case...

-- LLM evaluation:
-- The function behavior is well-defined for these happy-path inputs.
-- Each test exercises one format family with an unambiguous date.
--
-- "2024-03-15" → ISO 8601 date → { year: 2024, month: 3, day: 15 } → matches expected → pass
-- "2024-03-15T10:30:00Z" → ISO 8601 datetime → { year: 2024, month: 3, day: 15 } → pass
-- "03/15/2024" → US MM/DD/YYYY → { year: 2024, month: 3, day: 15 } → pass
-- "March 15 2024" → US natural → { year: 2024, month: 3, day: 15 } → pass
-- "15.03.2024" → European DD.MM.YYYY → { year: 2024, month: 3, day: 15 } → pass
-- "yesterday" → relative to today (2026-03-11) → { year: 2026, month: 3, day: 10 } → pass
-- "not-a-date-at-all" → unparseable → ValueError → pass

  yield results ≡ [
    { input: "2024-03-15", actual: { year: 2024, month: 3, day: 15 }, expected: { year: 2024, month: 3, day: 15 }, pass: true, explanation: "ISO 8601 date parsed correctly" },
    { input: "2024-03-15T10:30:00Z", actual: { year: 2024, month: 3, day: 15 }, expected: { year: 2024, month: 3, day: 15 }, pass: true, explanation: "ISO 8601 datetime — date portion extracted, time discarded" },
    { input: "03/15/2024", actual: { year: 2024, month: 3, day: 15 }, expected: { year: 2024, month: 3, day: 15 }, pass: true, explanation: "US format MM/DD/YYYY" },
    { input: "March 15 2024", actual: { year: 2024, month: 3, day: 15 }, expected: { year: 2024, month: 3, day: 15 }, pass: true, explanation: "US natural language month name" },
    { input: "15.03.2024", actual: { year: 2024, month: 3, day: 15 }, expected: { year: 2024, month: 3, day: 15 }, pass: true, explanation: "European DD.MM.YYYY" },
    { input: "yesterday", actual: { year: 2026, month: 3, day: 10 }, expected: { year: 2026, month: 3, day: 10 }, pass: true, explanation: "Relative date — 1 day before 2026-03-11" },
    { input: "not-a-date-at-all", actual: "ValueError", expected: "ValueError", pass: true, explanation: "Unparseable input correctly raises ValueError" }
  ]
  yield pass-count ≡ 7
  yield fail-count ≡ 0

-- oracle checks:
--   ⊨ len(results) = len(generate-initial-tests→test-cases) → ✓ (both 7)
--   ⊨ pass-count + fail-count = len(results) → ✓ (7 + 0 = 7)
--   ⊨ each result includes input, actual, expected, pass/fail, explanation → ✓

-- Ready set after frame 2: { discover-edge-cases }
-- run-tests→results is frozen. ⊢∘ evolve loop can begin.
-- NOTE: All initial tests pass — these are happy paths. The real challenge is edge cases.

-- ═══════════════════════════════════════════════════════════════
-- ⊢∘ evolve — ITERATION 0
-- ═══════════════════════════════════════════════════════════════

-- ═══════════════════════════════════════════════════════════════
-- frame 3: discover-edge-cases (iteration 0)
-- ═══════════════════════════════════════════════════════════════

-- Soft cell managed by ⊢∘ evolve. Oracles are ASPIRATIONAL.
-- given? refine-test-suite→refined-edge-cases is ⊥ (first iteration).

⊢ discover-edge-cases
  given run-tests→results ≡ [... all 7 passing results ...]
  given function-spec→behavior ≡ "Parses dates in any common format..."
  given generate-initial-tests→categories ≡ ["iso", "us", "european", "natural-language", "error"]
  given? refine-test-suite→refined-edge-cases ≡ ⊥
  yield edge-cases[], reasoning

  ∴ Analyze the test results and behavior spec. Identify edge cases MISSED...
    If «refine-test-suite→refined-edge-cases» is available (not ⊥), incorporate those.

-- LLM evaluation:
-- All 7 tests pass. The LLM analyzes WHAT'S MISSING:
-- 1. All inputs use March 15 2024 — no variation in actual date values
-- 2. No ambiguous inputs (all formats are unambiguous for the chosen date)
-- 3. No boundary dates (leap years, month/year edges)
-- 4. No partial inputs (missing day, missing year)
-- 5. Only one error case
-- 6. "yesterday" is the only relative date — no "next Tuesday", "in 3 days"
--
-- The LLM identifies 6 edge cases targeting specific risks:

  yield edge-cases ≡ [
    { input: "01/02/2024", expected-behavior: "Ambiguous: US → Jan 2, European → Feb 1. Spec doesn't specify priority. Should either pick a convention or raise ValueError.", category: "ambiguous", risk: "US/European format collision — no way to determine intent without locale" },
    { input: "02/29/2025", expected-behavior: "ValueError — 2025 is not a leap year", category: "boundary", risk: "Feb 29 on non-leap year must be rejected, not silently corrected to Feb 28 or Mar 1" },
    { input: "March 2024", expected-behavior: "Unclear — no day specified. Should raise ValueError or default to 1st?", category: "partial", risk: "Spec says 'Returns a Date with year, month, day fields' — what day when none given?" },
    { input: "", expected-behavior: "ValueError — empty string", category: "boundary", risk: "Empty input edge case — must not crash, must not return a default date" },
    { input: "next Tuesday", expected-behavior: "Relative to today (2026-03-11, a Wednesday) → 2026-03-17", category: "natural-language", risk: "Relative date anchoring — from when? Current time? UTC? Local?" },
    { input: "13/02/2024", expected-behavior: "Unambiguously European (month cannot be 13) → Feb 13 2024", category: "disambiguation", risk: "When month > 12, format is unambiguously DD/MM/YYYY — does the parser detect this?" }
  ]

  yield reasoning ≡ "Initial tests all use the same date (March 15 2024) in different formats — zero variation in actual date values. The biggest gap is ambiguous inputs: '01/02/2024' is valid in both US and European formats with different meanings. Boundary conditions (non-leap Feb 29, empty string) and partial inputs (month without day) are also untested. The natural language tests only cover 'yesterday' — 'next Tuesday' tests relative date anchoring, a known source of bugs."

-- oracle checks (ASPIRATIONAL under ⊢∘ management):
--   ⊨ len(edge-cases) >= 4 → ✓ (6 edge cases)
--   ⊨ each edge-case identifies a specific risk or ambiguity → ✓
--   ⊨ edge-cases includes at least one ambiguous input and one boundary case → ✓ ("01/02/2024" is ambiguous, "02/29/2025" is boundary)
--   ⊨ reasoning explains the discovery process → ✓

-- Ready set after frame 3: { spawn-edge-tests }

-- ═══════════════════════════════════════════════════════════════
-- frame 4: spawn-edge-tests (iteration 0)
-- ═══════════════════════════════════════════════════════════════

-- ⊢⊢ spawner with accumulate mode. Creates one cell per edge case.
-- Spawns 6 cells: edge-test-0 through edge-test-5.

⊢⊢ spawn-edge-tests
  given discover-edge-cases→edge-cases ≡ [... 6 edge cases ...]
  given function-spec→signature ≡ "parse_date(s: string) -> Date"
  given function-spec→behavior ≡ "Parses dates in any common format..."
  given §edge-test-template ≡ (definition of edge-test-template)
  yield §edge-test-cells[]
  until len(edge-test-cells) = len(discover-edge-cases→edge-cases)
  max 10
  accumulate

  ∴ For each edge case, spawn a test cell from «§edge-test-template»...

-- Spawner fires. Creates 6 cells from the template:
--
-- edge-test-0: edge-input ≡ "01/02/2024", expected-behavior ≡ "Ambiguous: US → Jan 2, European → Feb 1...", edge-rationale ≡ "US/European format collision"
-- edge-test-1: edge-input ≡ "02/29/2025", expected-behavior ≡ "ValueError — 2025 is not a leap year", edge-rationale ≡ "Feb 29 on non-leap year"
-- edge-test-2: edge-input ≡ "March 2024", expected-behavior ≡ "Unclear — no day specified...", edge-rationale ≡ "Spec requires day field"
-- edge-test-3: edge-input ≡ "", expected-behavior ≡ "ValueError — empty string", edge-rationale ≡ "Empty input edge case"
-- edge-test-4: edge-input ≡ "next Tuesday", expected-behavior ≡ "Relative to today → 2026-03-17", edge-rationale ≡ "Relative date anchoring"
-- edge-test-5: edge-input ≡ "13/02/2024", expected-behavior ≡ "Unambiguously European → Feb 13 2024", edge-rationale ≡ "Auto-disambiguation when month > 12"

  yield §edge-test-cells ≡ [edge-test-0, edge-test-1, edge-test-2, edge-test-3, edge-test-4, edge-test-5]

-- oracle checks:
--   ⊨ len(edge-test-cells) = len(discover-edge-cases→edge-cases) → ✓ (both 6)
--   ⊨ each spawned cell targets exactly one edge case → ✓

-- Ready set after frame 4: { edge-test-0, edge-test-1, edge-test-2, edge-test-3, edge-test-4, edge-test-5 }
-- All 6 spawned cells have their givens bound. Any can execute next.
-- Confluence: execution order doesn't matter — they're independent.

-- ═══════════════════════════════════════════════════════════════
-- frame 5: edge-test-0 (ambiguous US/European)
-- ═══════════════════════════════════════════════════════════════

⊢ edge-test-0
  given edge-input ≡ "01/02/2024"
  given expected-behavior ≡ "Ambiguous: US → Jan 2, European → Feb 1. Spec doesn't specify priority."
  given edge-rationale ≡ "US/European format collision — no way to determine intent without locale"
  given function-spec→signature ≡ "parse_date(s: string) -> Date"
  yield result, verdict, deeper-edges[]

  ∴ Simulate executing «function-spec→signature» on «edge-input»...

-- LLM evaluation:
-- "01/02/2024" — both US (Jan 2) and European (Feb 1) are valid parses.
-- The spec says "Parses dates in any common format" but doesn't specify
-- which format takes priority when multiple formats match.
-- The LLM must declare this ambiguous.

  yield result ≡ "Input '01/02/2024' has two valid interpretations: US format gives { year: 2024, month: 1, day: 2 }, European format gives { year: 2024, month: 2, day: 1 }. The behavior spec does not specify format priority or locale detection. This is a genuine spec ambiguity."
  yield verdict ≡ "ambiguous"
  yield deeper-edges ≡ [
    "02/03/2024 — same ambiguity, different date values",
    "12/11/2024 — ambiguous (Dec 11 US or Nov 12 European) but both months valid",
    "What locale detection should the parser use? IP? OS setting? Explicit parameter?"
  ]

-- oracle checks:
--   ⊨ verdict ∈ { "pass", "fail", "ambiguous" } → ✓ ("ambiguous")
--   ⊨ if verdict = "ambiguous" then result explains the ambiguity → ✓
--   ⊨ deeper-edges is a list (possibly empty) → ✓ (3 deeper edges)

-- Ready set after frame 5: { edge-test-1, edge-test-2, edge-test-3, edge-test-4, edge-test-5 }

-- ═══════════════════════════════════════════════════════════════
-- frame 6: edge-test-1 (Feb 29 non-leap year)
-- ═══════════════════════════════════════════════════════════════

⊢ edge-test-1
  given edge-input ≡ "02/29/2025"
  given expected-behavior ≡ "ValueError — 2025 is not a leap year"
  given edge-rationale ≡ "Feb 29 on non-leap year must be rejected"
  given function-spec→signature ≡ "parse_date(s: string) -> Date"
  yield result, verdict, deeper-edges[]

  ∴ Simulate executing «function-spec→signature» on «edge-input»...

-- LLM evaluation:
-- 2025 is not a leap year (not divisible by 4). Feb 29 doesn't exist.
-- The spec says "Raises ValueError on unparseable input."
-- This is parseable-format but invalid-date. The spec arguably covers this
-- since the date itself is invalid, but the FORMAT is valid.
-- A reasonable implementation would raise ValueError.

  yield result ≡ "Input '02/29/2025' is in valid US format MM/DD/YYYY but refers to a non-existent date (2025 is not a leap year). A well-implemented parse_date should raise ValueError since the resulting Date would have an invalid day. This tests calendar validation, not format parsing."
  yield verdict ≡ "pass"
  yield deeper-edges ≡ [
    "02/29/2000 — leap year (divisible by 400), should pass",
    "02/29/1900 — NOT a leap year (divisible by 100 but not 400)",
    "00/15/2024 — month 0 is invalid regardless of format"
  ]

-- oracle checks:
--   ⊨ verdict ∈ { "pass", "fail", "ambiguous" } → ✓ ("pass")
--   ⊨ if verdict = "ambiguous" then result explains the ambiguity → vacuously ✓
--   ⊨ deeper-edges is a list (possibly empty) → ✓ (3 deeper edges)

-- Ready set after frame 6: { edge-test-2, edge-test-3, edge-test-4, edge-test-5 }

-- ═══════════════════════════════════════════════════════════════
-- frame 7: edge-test-2 (partial input — no day)
-- ═══════════════════════════════════════════════════════════════

⊢ edge-test-2
  given edge-input ≡ "March 2024"
  given expected-behavior ≡ "Unclear — no day specified. Should raise ValueError or default to 1st?"
  given edge-rationale ≡ "Spec says 'Returns a Date with year, month, day fields' — what day when none given?"
  given function-spec→signature ≡ "parse_date(s: string) -> Date"
  yield result, verdict, deeper-edges[]

  ∴ Simulate executing «function-spec→signature» on «edge-input»...

-- LLM evaluation:
-- "March 2024" — month and year but no day. The spec requires a Date with
-- year, month, day fields. Two reasonable behaviors:
-- 1. Default day to 1 → { year: 2024, month: 3, day: 1 }
-- 2. Raise ValueError because the input is incomplete
-- The spec doesn't say "partial dates are accepted" or "missing fields default."
-- This is a spec gap.

  yield result ≡ "Input 'March 2024' is recognizable as a month-year reference but lacks a day component. The spec requires 'a Date with year, month, day fields' — the day field has no source. Two reasonable implementations: (1) default day to 1, (2) raise ValueError for incomplete input. The spec is silent on partial dates."
  yield verdict ≡ "ambiguous"
  yield deeper-edges ≡ [
    "2024 — just a year, even more partial",
    "Tuesday — day of week without date, even more ambiguous than 'next Tuesday'"
  ]

-- oracle checks:
--   ⊨ verdict ∈ { "pass", "fail", "ambiguous" } → ✓ ("ambiguous")
--   ⊨ if verdict = "ambiguous" then result explains the ambiguity → ✓
--   ⊨ deeper-edges is a list (possibly empty) → ✓ (2 deeper edges)

-- Ready set after frame 7: { edge-test-3, edge-test-4, edge-test-5 }

-- ═══════════════════════════════════════════════════════════════
-- frame 8: edge-test-3 (empty string)
-- ═══════════════════════════════════════════════════════════════

⊢ edge-test-3
  given edge-input ≡ ""
  given expected-behavior ≡ "ValueError — empty string"
  given edge-rationale ≡ "Empty input edge case — must not crash, must not return a default date"
  given function-spec→signature ≡ "parse_date(s: string) -> Date"
  yield result, verdict, deeper-edges[]

  ∴ Simulate executing «function-spec→signature» on «edge-input»...

-- LLM evaluation:
-- Empty string — clearly unparseable. Spec says "Raises ValueError on
-- unparseable input." This is unambiguous.

  yield result ≡ "Input '' (empty string) is unparseable. parse_date raises ValueError per spec."
  yield verdict ≡ "pass"
  yield deeper-edges ≡ [
    "   (whitespace only) — should also be ValueError",
    "null/None — if the language distinguishes null from empty string"
  ]

-- oracle checks:
--   ⊨ verdict ∈ { "pass", "fail", "ambiguous" } → ✓ ("pass")
--   ⊨ if verdict = "ambiguous" then result explains the ambiguity → vacuously ✓
--   ⊨ deeper-edges is a list (possibly empty) → ✓ (2 deeper edges)

-- Ready set after frame 8: { edge-test-4, edge-test-5 }

-- ═══════════════════════════════════════════════════════════════
-- frame 9: edge-test-4 (next Tuesday — relative anchoring)
-- ═══════════════════════════════════════════════════════════════

⊢ edge-test-4
  given edge-input ≡ "next Tuesday"
  given expected-behavior ≡ "Relative to today (2026-03-11, a Wednesday) → 2026-03-17"
  given edge-rationale ≡ "Relative date anchoring — from when? Current time? UTC? Local?"
  given function-spec→signature ≡ "parse_date(s: string) -> Date"
  yield result, verdict, deeper-edges[]

  ∴ Simulate executing «function-spec→signature» on «edge-input»...

-- LLM evaluation:
-- "next Tuesday" — today is 2026-03-11 (Wednesday).
-- Next Tuesday = 2026-03-17 (6 days from now).
-- The spec lists "next Tuesday" as an accepted format.
-- But the result depends on WHEN parse_date is called and WHAT timezone.
-- If this test is run on a different day, the expected output changes.
-- This is a test design problem, not a parser problem.

  yield result ≡ "Input 'next Tuesday' parsed relative to today 2026-03-11 (Wednesday) gives { year: 2026, month: 3, day: 17 }. This matches expected behavior. However, this test is FRAGILE: the expected output depends on the execution date. Any test suite using relative dates needs either (a) a fixed reference date parameter, or (b) dynamic expected values."
  yield verdict ≡ "pass"
  yield deeper-edges ≡ [
    "Does 'next Tuesday' on a Tuesday mean today or 7 days from now?",
    "What timezone anchors 'today'? UTC? System local?",
    "in 3 days — tests arithmetic relative dates"
  ]

-- oracle checks:
--   ⊨ verdict ∈ { "pass", "fail", "ambiguous" } → ✓ ("pass")
--   ⊨ if verdict = "ambiguous" then result explains the ambiguity → vacuously ✓
--   ⊨ deeper-edges is a list (possibly empty) → ✓ (3 deeper edges)

-- Ready set after frame 9: { edge-test-5 }

-- ═══════════════════════════════════════════════════════════════
-- frame 10: edge-test-5 (unambiguous European — month > 12)
-- ═══════════════════════════════════════════════════════════════

⊢ edge-test-5
  given edge-input ≡ "13/02/2024"
  given expected-behavior ≡ "Unambiguously European (month cannot be 13) → Feb 13 2024"
  given edge-rationale ≡ "Auto-disambiguation when month > 12"
  given function-spec→signature ≡ "parse_date(s: string) -> Date"
  yield result, verdict, deeper-edges[]

  ∴ Simulate executing «function-spec→signature» on «edge-input»...

-- LLM evaluation:
-- "13/02/2024" — if read as US MM/DD/YYYY → month 13 is invalid.
-- Must be European DD/MM/YYYY → day 13, month 2 → Feb 13 2024.
-- A smart parser should detect this and apply European format.
-- But the spec doesn't say "auto-detect format" — it says "accepts...
-- European format (15/03/2024)." Does it try European format for
-- slash-separated dates, or only US format by default?

  yield result ≡ "Input '13/02/2024' is unambiguously DD/MM/YYYY because 13 cannot be a month. parse_date should detect this and produce { year: 2024, month: 2, day: 13 }. This tests whether the parser attempts multiple format hypotheses or blindly applies US format first. A parser that only tries MM/DD/YYYY would reject this with ValueError for month 13."
  yield verdict ≡ "pass"
  yield deeper-edges ≡ [
    "31/12/2024 — another unambiguously European date (day 31, month 12)",
    "What if the parser tries US first, fails, then tries European? Error messages would be confusing."
  ]

-- oracle checks:
--   ⊨ verdict ∈ { "pass", "fail", "ambiguous" } → ✓ ("pass")
--   ⊨ if verdict = "ambiguous" then result explains the ambiguity → vacuously ✓
--   ⊨ deeper-edges is a list (possibly empty) → ✓ (2 deeper edges)

-- Ready set after frame 10: { assess-coverage }
-- All 6 edge-test-* cells frozen. Wildcard deps edge-test-*→result,
-- edge-test-*→verdict, edge-test-*→deeper-edges now resolve.

