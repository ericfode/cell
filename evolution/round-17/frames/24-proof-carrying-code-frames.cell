  given generate-proof→invariants ≡ ["At each iteration, result[0..k] is sorted and contains exactly the elements a[0..i] ∪ b[0..j] where k = i + j"]
  given generate-proof→termination-argument ≡ "i + j increases by exactly 1 each iteration, bounded above by len(a) + len(b). Loop exits when i = len(a) or j = len(b)."
  given generate-proof→properties-proved ≡ ["sortedness", "permutation", "termination", "postcondition"]
  yield struct-valid, step-count, has-invariant, has-termination, covers-required

-- ⊢= deterministic evaluation (v0.2 valid primitives only):

  ⊢= step-count ← len(split("**1. Loop Invariant**: ...***2. Sortedness**...**3. Permutation**...**4. Termination**...**5. Postcondition**...", "**")) / 2
  -- split on "**" yields ~11 segments, / 2 = 5

  yield step-count ≡ 5

  ⊢= has-invariant ← any(["At each iteration, result[0..k]...a[0..i] ∪ b[0..j] where k = i + j"], fn(inv) → contains(inv, "i") and contains(inv, "j") and contains(inv, "result"))
  -- contains("...a[0..i]...", "i") = true, contains("...b[0..j]...", "j") = true, contains("...result[0..k]...", "result") = true
  -- any([true]) = true

  yield has-invariant ≡ true

  ⊢= has-termination ← contains("i + j increases by exactly 1 each iteration, bounded above by len(a) + len(b)...", "increase") or contains(..., "monoton") or contains(..., "decrease") or contains(..., "bound")
  -- contains(termination-argument, "increase") = true (first disjunct short-circuits)

  yield has-termination ≡ true

  ⊢= covers-required ← any(["sortedness", "permutation", "termination", "postcondition"], fn(p) → contains(lower(p), "sorted")) and any([...], fn(p) → contains(lower(p), "permutation"))
  -- any([true, false, false, false]) = true AND any([false, true, false, false]) = true

  yield covers-required ≡ true

  ⊢= struct-valid ← 5 >= 5 and true and true and true

  yield struct-valid ≡ true

