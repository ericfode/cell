⊢ generate-code
  given spec→description ≡ "merge two sorted lists into one sorted list"
  given spec→signature ≡ "merge_sorted(a: int[], b: int[]) -> int[]"
  given spec→preconditions ≡ "a is sorted ascending, b is sorted ascending"
  yield §implementation, code-text

  ∴ Write a correct implementation of «spec→signature» that satisfies:
    «spec→description»
    Preconditions: «spec→preconditions»
    ...

-- LLM evaluation:

  yield implementation ≡ §(
    ⊢= merge_sorted ← fn(a, b) →
      let i ← 0, j ← 0, result ← []
      while i < len(a) and j < len(b):
        if a[i] <= b[j]:
          result ← concat(result, [a[i]])
          i ← i + 1
        else:
          result ← concat(result, [b[j]])
          j ← j + 1
      result ← concat(result, drop(a, i))
      result ← concat(result, drop(b, j))
      result
  )

  yield code-text ≡ "fn merge_sorted(a: int[], b: int[]) -> int[]: let i=0, j=0, result=[]; while i < len(a) and j < len(b): if a[i] <= b[j] then append a[i], i+=1 else append b[j], j+=1; append remaining a[i..] then b[j..]; return result"

-- oracle checks:
--   ⊨ code-text contains a loop or iterative structure → ✓ ("while i < len(a) and j < len(b)")
--   ⊨ code-text compares elements from both lists → ✓ ("if a[i] <= b[j]")
--   ⊨ code-text handles the case when one list is exhausted → ✓ ("append remaining a[i..] then b[j..]")

