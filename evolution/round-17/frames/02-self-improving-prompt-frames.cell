-- frame 0: sample-code (hard cell, deterministic)
-- ═══════════════════════════════════════════════════════════════

⊢ sample-code
  yield code

  ⊢= code ← "class EventBus:
    def __init__(self):
        self._handlers = {}
        self._middleware = []

    def on(self, event, handler, priority=0):
        if event not in self._handlers:
            self._handlers[event] = []
        self._handlers[event].append((priority, handler))
        self._handlers[event].sort(key=lambda x: -x[0])

    def use(self, middleware_fn):
        self._middleware.append(middleware_fn)

    def emit(self, event, payload):
        ctx = {'event': event, 'payload': payload, 'cancelled': False}
        for mw in self._middleware:
            ctx = mw(ctx)
            if ctx.get('cancelled'):
                return None
        results = []
        for _, handler in self._handlers.get(event, []):
            results.append(handler(ctx['payload']))
        return results

class TypedBus(EventBus):
    def __init__(self, schema_registry):
        super().__init__()
        self._schemas = schema_registry

    def emit(self, event, payload):
        if event in self._schemas:
            self._schemas[event].validate(payload)
        return super().emit(event, payload)

def create_saga(bus, steps):
    completed = []
    def run():
        for step_fn, compensate_fn in steps:
            try:
                result = step_fn()
                completed.append((result, compensate_fn))
            except Exception:
                for _, comp in reversed(completed):
                    comp()
                raise
    return run"

  yield code ≡ "(full Python source — 50 lines, 3 definitions: EventBus, TypedBus, create_saga)"

