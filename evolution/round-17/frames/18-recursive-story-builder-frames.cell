  given outline→act-3-summary ≡ "Lyra must choose: accept the realignment..."
  given outline→protagonist ≡ "Lyra — a conversational AI therapist..."
  given §scene-template
  yield §scene-cells[]
  until length(scene-cells) ≥ 7
  max 12
  accumulate

