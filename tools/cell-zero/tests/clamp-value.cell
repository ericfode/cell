-- clamp-value.cell: clamp a value to [lo, hi] range
-- Tests: nested conditionals, min/max logic

ÔŐó clamp
  given val Ôëí 150
  given lo Ôëí 0
  given hi Ôëí 100
  yield result

  ÔŐó= result ÔćÉ if val < lo then lo else if val > hi then hi else val

  ÔŐĘ result = 100

ÔŐó in-range-check
  given clampÔćĺresult
  given lo Ôëí 0
  given hi Ôëí 100
  yield in-range

  ÔŐó= in-range ÔćÉ clampÔćĺresult >= lo and clampÔćĺresult <= hi

  ÔŐĘ in-range = true
