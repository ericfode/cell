-- fizzbuzz.cell: classic fizzbuzz with conditional dispatch
-- Tests: nested if/then/else, modular arithmetic, guards

‚äĘ classify
  given n ‚Č° 15
  yield label

  ‚äĘ= label ‚Üź if n % 15 == 0 then "fizzbuzz" else if n % 3 == 0 then "fizz" else if n % 5 == 0 then "buzz" else "number"

  ‚ä® label = "fizzbuzz"

‚äĘ handle-fizzbuzz
  given classify‚Üílabel where label = "fizzbuzz"
  yield output

  ‚äĘ= output ‚Üź "FizzBuzz!"

  ‚ä® output = "FizzBuzz!"

‚äĘ handle-fizz
  given classify‚Üílabel where label = "fizz"
  yield output

  ‚äĘ= output ‚Üź "Fizz"

‚äĘ handle-buzz
  given classify‚Üílabel where label = "buzz"
  yield output

  ‚äĘ= output ‚Üź "Buzz"

‚äĘ handle-number
  given classify‚Üílabel where label = "number"
  given n ‚Č° 15
  yield output

  ‚äĘ= output ‚Üź n
