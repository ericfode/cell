-- grade-calculator.cell: score to letter grade with 5-way guard dispatch
-- Tests: many guards, complex if/then/else, string output

‚äĘ assign-grade
  given score ‚Č° 85
  yield grade

  ‚äĘ= grade ‚Üź if score >= 90 then "A" else if score >= 80 then "B" else if score >= 70 then "C" else if score >= 60 then "D" else "F"

  ‚ä® grade = "B"

‚äĘ handle-a
  given assign-grade‚Üígrade where grade = "A"
  yield feedback

  ‚äĘ= feedback ‚Üź "Excellent work!"

‚äĘ handle-b
  given assign-grade‚Üígrade where grade = "B"
  yield feedback

  ‚äĘ= feedback ‚Üź "Good job!"

  ‚ä® feedback = "Good job!"

‚äĘ handle-c
  given assign-grade‚Üígrade where grade = "C"
  yield feedback

  ‚äĘ= feedback ‚Üź "Satisfactory."

‚äĘ handle-fail
  given assign-grade‚Üígrade where grade = "F"
  yield feedback

  ‚äĘ= feedback ‚Üź "Please see instructor."
