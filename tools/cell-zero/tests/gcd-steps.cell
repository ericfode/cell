-- gcd-steps.cell: GCD via Euclidean algorithm unrolled as cell chain
-- Tests: modular arithmetic, conditional termination, deep chain

ÔŐó step0
  given a Ôëí 48
  given b Ôëí 18
  yield remainder

  ÔŐó= remainder ÔćÉ a % b

  ÔŐĘ remainder = 12

ÔŐó step1
  given prev-b Ôëí 18
  given step0Ôćĺremainder
  yield remainder

  ÔŐó= remainder ÔćÉ prev-b % step0Ôćĺremainder

  ÔŐĘ remainder = 6

ÔŐó step2
  given prev-b Ôëí 12
  given step1Ôćĺremainder
  yield remainder

  ÔŐó= remainder ÔćÉ prev-b % step1Ôćĺremainder

  ÔŐĘ remainder = 0

ÔŐó result
  given step2Ôćĺremainder
  given step1Ôćĺremainder
  yield gcd

  ÔŐó= gcd ÔćÉ if step2Ôćĺremainder == 0 then step1Ôćĺremainder else step2Ôćĺremainder

  ÔŐĘ gcd = 6
