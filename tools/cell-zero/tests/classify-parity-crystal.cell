-- classify-parity-crystal.cell: even/odd classifier
-- Oracle: if even then n%2=0, if odd then n%2=1

вҠў check-parity
  given n вүЎ 7
  yield parity

  вҲҙ Is В«nВ» even or odd? Return "even" or "odd".

вҠў verify-parity
  given check-parityвҶ’parity
  given n вүЎ 7
  yield consistent

  вҲҙ Check: if В«check-parityвҶ’parityВ» is "even", verify 7 % 2 = 0.
    If "odd", verify 7 % 2 = 1. Return true if consistent.

  вҠЁ consistent = true

вҠў handle-even
  given check-parityвҶ’parity where parity = "even"
  given n вүЎ 7
  yield message

  вҠў= message вҶҗ "The number is even"

вҠў handle-odd
  given check-parityвҶ’parity where parity = "odd"
  given n вүЎ 7
  yield message

  вҠў= message вҶҗ "The number is odd"

вҠў crystallize
  given В§check-parity
  given verify-parityвҶ’consistent where consistent = true
  yield В§check-parity', is-faithful

  вҲҙ Read В«В§check-parityВ». It classifies even/odd.
    Write a вҠў= expression: if n % 2 = 0 then "even" else "odd"
