-- pipeline-transform.cell: multi-stage data transformation pipeline
-- Tests: 5-stage pipeline, string + number ops, mixed types

‚äĘ input-data
  given raw ‚Č° "42"
  yield text

  ‚äĘ= text ‚Üź raw

‚äĘ parse-number
  given input-data‚Üítext
  yield num

  ‚äĘ= num ‚Üź int(input-data‚Üítext)

  ‚ä® num = 42

‚äĘ double-it
  given parse-number‚Üínum
  yield doubled

  ‚äĘ= doubled ‚Üź parse-number‚Üínum * 2

  ‚ä® doubled = 84

‚äĘ stringify
  given double-it‚Üídoubled
  yield text

  ‚äĘ= text ‚Üź str(double-it‚Üídoubled)

  ‚ä® text = "84"

‚äĘ report
  given stringify‚Üítext
  given double-it‚Üídoubled
  yield message

  ‚äĘ= message ‚Üź "Result: " + stringify‚Üítext

  ‚ä® message = "Result: 84"
