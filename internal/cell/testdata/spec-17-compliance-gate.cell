# Spec Section 17: Complex Oracle
# Oracle cell with quality scoring

cell compliance-gate {
    type: oracle
    prompt: """
        Validate trade action:
        - action must be BUY, SELL, or HOLD
        - quantity must be 1-1000000
        - rationale must be >= 200 chars for BUY/SELL
        - no placeholder or TBD text
        - quality scoring based on rationale depth
    """
}
