-- hard-eval.cell: Experiment 0 ÔÇö Verify the hard cell expression evaluator
-- Tests: arithmetic, lists, guards, conditionals, builtins, oracles
-- Expected: all cells freeze with correct values, no oracle failures
-- Run: rt load experiments/hard-eval.cell && rt eval

-- Basic arithmetic
Ôèó arithmetic
  yield sum
  yield product
  yield modulo
  Ôèó= sum ÔåÉ 3 + 5
      product ÔåÉ 7 * 6
      modulo ÔåÉ 17 % 5
  Ôè¿ sum = 8
  Ôè¿ product = 42
  Ôè¿ modulo = 2

-- List operations
Ôèó lists
  yield original Ôëí [5, 3, 1, 4, 2]
  yield sorted
  yield reversed
  yield total
  yield length
  Ôèó= sorted ÔåÉ sorted(original)
      reversed ÔåÉ reversed(original)
      total ÔåÉ sum(original)
      length ÔåÉ len(original)
  Ôè¿ sorted = [1, 2, 3, 4, 5]
  Ôè¿ total = 15
  Ôè¿ length = 5

-- String operations
Ôèó strings
  yield greeting Ôëí "hello world"
  yield upper
  yield words
  yield joined
  Ôèó= upper ÔåÉ upper(greeting)
      words ÔåÉ split(greeting, " ")
      joined ÔåÉ join(words, "-")
  Ôè¿ upper = "HELLO WORLD"
  Ôè¿ joined = "hello-world"

-- Conditional logic
Ôèó conditionals
  given arithmeticÔåÆsum
  yield classified
  yield sign
  Ôèó= classified ÔåÉ if sum > 5 then "big" else "small"
      sign ÔåÉ if sum > 0 then "positive" else if sum = 0 then "zero" else "negative"
  Ôè¿ classified = "big"
  Ôè¿ sign = "positive"

-- Guard branches ÔÇö only one should fire
Ôèó positive-path
  given arithmeticÔåÆsum where sum > 0
  yield label
  Ôèó= "sum is positive"
  Ôè¿ label = "sum is positive"

Ôèó negative-path
  given arithmeticÔåÆsum where sum < 0
  yield label
  Ôèó= "sum is negative"

-- Iterator predicates
Ôèó verification
  given listsÔåÆsorted
  yield is-sorted
  yield has-positives
  yield count-gt-2
  Ôèó= is-sorted ÔåÉ all(i, sorted[i] <= sorted[i+1])
      has-positives ÔåÉ any(i, sorted[i] > 0)
      count-gt-2 ÔåÉ count(sorted, x, x > 2)
  Ôè¿ is-sorted = true
  Ôè¿ has-positives = true
  Ôè¿ count-gt-2 = 3

-- Downstream aggregation
Ôèó summary
  given arithmeticÔåÆsum
  given arithmeticÔåÆproduct
  given listsÔåÆtotal
  given stringsÔåÆupper
  given conditionalsÔåÆclassified
  given verificationÔåÆis-sorted
  yield all-passed
  Ôèó= all([sum = 8, product = 42, total = 15, upper = "HELLO WORLD", classified = "big", is-sorted = true])
  Ôè¿ all-passed = true
