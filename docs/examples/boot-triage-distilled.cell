-- Boot Triage (Distilled) — after 50 patrol cycles, the decide cell is frozen.
-- The LLM consistently maps observation patterns to the same actions.
-- Distillation captures this mapping. Zero-cost, deterministic, instant.
--
-- This is boot-triage.cell after Phase 1 distillation.
-- Only the `decide` cell changed: llm → distilled.

## boot-triage

  # observe : script
    ```bash
    echo "=== DEACON STATE ==="
    tmux has-session -t hq-deacon 2>/dev/null && echo "deacon_alive=true" || echo "deacon_alive=false"
    gt peek deacon --lines 20 2>/dev/null || echo "peek_failed=true"
    echo "=== BEAD STATE ==="
    bd show hq-deacon --json 2>/dev/null || echo "bead_missing=true"
    echo "=== ACTIVITY ==="
    gt feed --since 10m --plain 2>/dev/null | head -20
    echo "=== MAIL ==="
    gt mail inbox deacon 2>/dev/null | head -10 | wc -l | xargs -I{} echo "pending_mail={}"
    ```
  #/

  -- DISTILLED: This cell was llm for 50 cycles. Oracle passed every time.
  -- The LLM always mapped the same observation patterns to the same actions.
  -- Frozen on 2026-03-09 after reviewing execution history.
  # decide : distilled
    - observe

    distill>
      input_pattern: "{{observe}}"
      output_map: {
        "deacon_alive=false" -> { action: "START", reason: "Dead session", confidence: 0.99 },
        "deacon_alive=true.*peek_failed=true" -> { action: "START", reason: "Session zombie", confidence: 0.95 },
        "deacon_alive=true.*pending_mail=0.*idle < 300" -> { action: "NOTHING", reason: "Healthy and idle", confidence: 0.98 },
        "deacon_alive=true.*pending_mail=[1-9].*idle > 300" -> { action: "NUDGE", reason: "Has mail, idle", confidence: 0.90 },
        "deacon_alive=true.*idle > 900" -> { action: "WAKE", reason: "Idle too long", confidence: 0.85 },
        "deacon_alive=true.*error.*error" -> { action: "INTERRUPT", reason: "Repeated errors", confidence: 0.80 }
      }
      fallback: llm

    ```oracle
    json_parse(output);
    keys_present(output, ["action", "reason"]);
    assert output.action in ["NOTHING", "NUDGE", "WAKE", "INTERRUPT", "START"];
    ```
  #/

  # act : script
    - decide
    ```bash
    ACTION="{{decide.action}}"
    case "$ACTION" in
      NOTHING) echo "No action needed." ;;
      NUDGE) gt nudge --mode=queue deacon "Boot check-in: pending work" ;;
      WAKE) tmux send-keys -t hq-deacon Escape; sleep 1; gt nudge deacon "Boot wake" ;;
      INTERRUPT) gt mail send deacon -s "INTERRUPT" -m "{{decide.reason}}" ;;
      START) gt deacon start; echo "Started deacon." ;;
    esac
    ```
  #/

  # cleanup : script
    - act
    ```bash
    gt mail inbox deacon --json 2>/dev/null | \
      python3 -c "import json,sys; [print(m['id']) for m in json.load(sys.stdin) if 'handoff' in m.get('subject','').lower()]" | \
      while read mid; do [ -n "$mid" ] && gt mail archive "$mid" 2>/dev/null; done
    echo "Cleanup complete."
    ```
  #/

  # exit : script
    - cleanup
    ```bash
    if [ "${GT_DEGRADED}" = "true" ]; then
      echo "Boot triage complete (degraded): {{decide.action}}"
    else
      gt mail send boot -s "Boot handoff" -m "Action: {{decide.action}} Reason: {{decide.reason}}"
    fi
    ```
  #/

  squash> trigger: on_complete template: work include_metrics: true

