-- CELL ZERO — The Distillation Runtime
--
-- This is the first Cell program. It watches other cells execute and
-- crystallizes the ones that prove stable. It is the core of Cell:
-- the idea that if you execute a cell program enough times, it will
-- autonomously distill everything possible.
--
-- Cell Zero runs as a background molecule alongside any other molecule.
-- It observes, measures, proposes, validates, and freezes.
--
-- The lifecycle of every LLM cell:
--   llm → (observed) → (candidate) → (validated) → distilled
--
-- Cell Zero is itself subject to distillation. After enough runs,
-- its own observation and proposal cells will crystallize. The runtime
-- optimizes itself through use.

## cell-zero

  input param.target_molecule : str required
  input param.min_runs : number default(10)
  input param.consistency_threshold : number default(0.95)

  -- Phase 0: Validate — Cell Zero only executes valid Cell
  --
  -- Before observing anything, parse the target molecule through
  -- cell-reader. If it doesn't parse clean, reject it. This is
  -- the gate that ensures Cell Zero never distills garbage.
  -- As cell-reader itself distills, this gate gets faster.

  # load-source : script
    ```bash
    # Load the .cell source for the target molecule
    cell_file=$(bd mol source "{{param.target_molecule}}" 2>/dev/null)
    if [ -z "$cell_file" ]; then
      echo "ERROR: no source found for {{param.target_molecule}}"
      exit 1
    fi
    cat "$cell_file"
    ```
  #/

  # validate-cell : mol(cell-reader)
    - load-source
    param.source = "{{load-source}}"
    param.filename = "{{param.target_molecule}}.cell"
  #/

  # gate-valid : decision
    - validate-cell
    system>
      You are the validity gate. If the Cell source parsed clean,
      proceed. If there were parse errors, stop — Cell Zero does
      not distill invalid Cell.
    context>
      Parse result:
      {{validate-cell}}
    user>
      Did the parse succeed with zero errors?
      If valid: PROCEED. If errors: REJECT with details.
    format> gate
      { action: "PROCEED" | "REJECT", errors: [str] }

    ```oracle
    json_parse(output);
    assert output.action in ["PROCEED", "REJECT"];
    reject if output.action == "REJECT";
    ```
  #/

  -- Phase 0.5: Pour — execute the molecule, record results as beads
  --
  -- Cell Zero doesn't just observe — it actively pours the target molecule.
  -- Each pour produces execution data that feeds the distillation pipeline.
  -- The pour itself is tracked as a bead for auditability.

  # pour : script
    - gate-valid
    ```bash
    # Create a bead to track this pour
    pour_id=$(bd create "Pour: {{param.target_molecule}}" \
      --description="Cell Zero pour cycle" -t task -p 3 --json 2>/dev/null | \
      python3 -c "import json,sys; print(json.load(sys.stdin)['id'])")
    echo "pour_bead=$pour_id"

    # Sling the target molecule for execution
    gt sling "$pour_id" gastown \
      -m "Execute {{param.target_molecule}}.cell — you are the Cell runtime. Follow each cell in order. Validate against oracles. Record results." \
      --no-merge 2>&1

    echo "pour_dispatched=true"
    ```
  #/

  # pour-wait : script
    - pour
    ```bash
    # Wait for the pour to complete (poll bead status)
    pour_id="{{pour.pour_bead}}"
    for i in $(seq 1 60); do
      status=$(bd show "$pour_id" --json 2>/dev/null | \
        python3 -c "import json,sys; print(json.load(sys.stdin).get('status','open'))")
      if [ "$status" = "closed" ]; then
        echo "pour_complete=true"
        bd show "$pour_id" --json 2>/dev/null
        exit 0
      fi
      sleep 30
    done
    echo "pour_timeout=true"
    ```
  #/

  -- Phase 1: Observe — watch cells execute, record history

  # observe : script
    - pour-wait
    ```bash
    # Query execution history for target molecule
    bd mol history "{{param.target_molecule}}" --json 2>/dev/null
    # For each LLM cell, extract:
    # - input hash (blake3 of assembled prompt)
    # - output hash (blake3 of output)
    # - oracle verdict (pass/fail)
    # - latency (time to complete)
    ```
  #/

  # analyze : llm
    - observe
    system>
      You are the distillation analyzer. You examine cell execution
      history and identify candidates for crystallization.

      A cell is a distillation candidate when:
      1. It has been executed >= {{param.min_runs}} times
      2. Its oracle passes >= {{param.consistency_threshold}} of the time
      3. Its output shape is stable (same keys, similar structure)
      4. Input→output mapping is learnable (not random/creative)

      Cells that should NOT be distilled:
      - Creative writing cells (output intentionally varies)
      - Cells with @temperature > 0.5 (high variance by design)
      - Meta cells (they emit Cell source — freezing kills evolution)
      - Cells marked @no-distill
    context>
      Execution history:
      {{observe}}
    user>
      Identify distillation candidates. For each:
      1. Cell name and current type
      2. Run count and oracle pass rate
      3. Output stability score (0-1)
      4. Proposed input→output mapping
      5. Estimated cost savings
    format> candidates
      {
        analyzed: number,
        candidates: [{
          cell: str,
          runs: number,
          pass_rate: number,
          stability: number,
          mapping_size: number,
          monthly_cost_saved: number
        }],
        skip_reasons: [{ cell: str, reason: str }]
      }

    ```oracle
    json_parse(output);
    keys_present(output, ["analyzed", "candidates"]);
    for c in output.candidates {
      assert c.runs >= {{param.min_runs}};
      assert c.pass_rate >= {{param.consistency_threshold}};
    }
    ```
  #/

  -- Phase 2: Propose — generate distillation blocks

  map # propose : llm over {{analyze.candidates}} as candidate
    system>
      You are generating a distill> block for a Cell cell.
      The distill> block captures the input→output mapping
      observed across multiple executions.

      The mapping uses regex patterns on input and returns
      the observed output. Include a fallback to llm for
      novel inputs.
    user>
      Generate a distill> block for cell "{{candidate.cell}}".
      It was executed {{candidate.runs}} times with {{candidate.pass_rate}} pass rate.

      Build the input_pattern → output mapping from execution history.
      Cover the most common input patterns first.
      Always include `fallback: llm` for unmatched patterns.
    format> distillation
      {
        cell: str,
        distill_block: str,
        patterns_covered: number,
        coverage_pct: number
      }

    ```oracle
    json_parse(output);
    assert output.coverage_pct >= 0.8;
    assert output.distill_block contains "fallback:";
    ```
  #/

  -- Phase 3: Validate — test distilled cells against live execution

  map # validate : llm over {{propose.*}} as proposal
    system>
      You are validating a proposed distillation.
      Compare the distilled output against what the LLM would produce.
      The distillation is valid if outputs match for all test inputs.
    user>
      For cell "{{proposal.cell}}":
      1. Take 5 recent inputs from execution history
      2. Run them through the proposed distill> mapping
      3. Compare against the actual LLM outputs
      4. Report match rate
    format> validation
      {
        cell: str,
        test_count: number,
        match_count: number,
        match_rate: number,
        mismatches: [{ input_hash: str, expected: str, got: str }]
      }

    ```oracle
    json_parse(output);
    assert output.match_rate >= 0.9;
    reject if output.match_rate < 0.8;
    ```
  #/

  -- Phase 4: Freeze — apply validated distillations

  # freeze : llm
    - validate
    system>
      You are applying validated distillations to the target molecule.
      For each validated cell, rewrite its definition:
      - Change cell_type from "llm" to "distilled"
      - Replace prompt sections with a distill> block
      - Preserve oracle block (for runtime validation)
      - Add provenance comment with run count and date
    context>
      Validated distillations:
      each> v in {{validate.*}}
        Cell: {{v.cell}} — match rate: {{v.match_rate}}
    user>
      Generate the Cell source patches to apply these distillations.
      Only freeze cells with match_rate >= 0.9.
      Output the modified .cell file sections.
    format> patches
      {
        frozen: [{ cell: str, match_rate: number }],
        skipped: [{ cell: str, reason: str }],
        total_cost_saved: number
      }
  #/

  -- Phase 5: Report — what did Cell Zero accomplish?

  # report : llm
    - freeze
    - analyze
    system>
      You are writing the distillation report. Be precise.
    user>
      Distillation cycle complete for {{param.target_molecule}}.

      Analyzed: {{analyze.analyzed}} cells
      Candidates: {{analyze.candidates}}
      Frozen: {{freeze.frozen}}
      Skipped: {{freeze.skipped}}
      Cost saved: {{freeze.total_cost_saved}}/month

      Write a one-paragraph summary.
    format> report
      {
        molecule: str,
        cells_analyzed: number,
        cells_distilled: number,
        cells_skipped: number,
        monthly_savings: number,
        distillation_pct: number,
        summary: str
      }
  #/

  squash> trigger: on_complete template: distillation include_metrics: true

##/
